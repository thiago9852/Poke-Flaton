{% extends 'base.html.twig' %}

{% block title %}PokeFlaton | Movesets de Pokémons
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
	<link rel="stylesheet" href="{{ asset('css/pokemon.css') }}">
	<link rel="stylesheet" href="{{ asset('css/home.css') }}">
{% endblock %}

{% block body %}
	<section class="landing-hero">
		<div class="landing-hero-glow"></div>
		<h1 class="hero-title">{{ 'Encontre os Melhores'|trans }}
			<span class="highlight">Movesets</span>
		</h1>
		<p class="hero-subtitle">{{ 'Crie, compartilhe e explore as melhores combinações de golpes, natures, habilidades e localizações para seus Pokémon.'|trans }}</p>

		<div class="landing-search-container">
			<form action="{{ path('app_pokemon_index') }}" method="GET" class="search-form">
				<div class="search-box" style="position: relative;">
					<input type="text" id="global-search-input" name="q" placeholder="{{ 'Buscar Pokémon por nome ou número...'|trans }}" class="search-input" required autocomplete="off">
					<i class="fa-solid fa-magnifying-glass search-icon"></i>
					<div id="search-autocomplete-results" class="autocomplete-dropdown"></div>
				</div>
			</form>
		</div>
	</section>

	<!-- Cards -->
	<section class="landing-features-grid">
		<div class="feature-card">
			<div class="feature-card-glow"></div>
			<div class="feature-icon-wrapper">
				<i class="fa-solid fa-shield-halved"></i>
			</div>
			<h3 class="feature-title">{{ 'Movesets'|trans }}</h3>
			<p class="feature-desc">{{ 'Crie e explore as melhores combinações de golpes para os Pokémon.'|trans }}</p>
		</div>

		<div class="feature-card">
			<div class="feature-card-glow"></div>
			<div class="feature-icon-wrapper">
				<i class="fa-solid fa-bag-shopping"></i>
			</div>
			<h3 class="feature-title">{{ 'Builds Completas'|trans }}</h3>
			<p class="feature-desc">{{ 'Sugira a combinação ideal de Held Item, Nature recomendada e Habilidade para potencializar seu Pokémon.'|trans }}</p>
		</div>

		<div class="feature-card">
			<div class="feature-card-glow"></div>
			<div class="feature-icon-wrapper">
				<i class="fa-solid fa-location-dot"></i>
			</div>
			<h3 class="feature-title">{{ 'Localizações'|trans }}</h3>
			<p class="feature-desc">{{ 'Cadastre e encontre onde achar seus Pokémon favoritos.'|trans }}</p>
		</div>
	</section>

	<!-- Gerações Disponíveis -->
	<section class="generations-section">
		<h2 class="generations-title">
			<i class="fa-solid fa-gamepad" style="color: var(--color-primary); text-shadow: 0 0 10px rgba(139, 92, 246, 0.4);"></i>
			{{ 'Gerações'|trans }}
		</h2>
		<div class="generations-grid">
			{% for gen in generations %}
				<a href="{{ path('app_pokemon_index', { gen: gen.number }) }}" class="generation-card">
					<div class="gen-card-glow"></div>
					<span class="gen-badge">GEN {{ gen.number }}</span>
					<h3 class="gen-games">{{ gen.games }}</h3>
					<span class="gen-region">{{ gen.region }}</span>
					<span class="gen-count">{{ gen.count }} Pokémon</span>
				</a>
			{% endfor %}
		</div>
	</section>

	<!-- Pokémons em Alta -->
	<section class="trending-section">
		<h2 class="trending-title">
			<i class="fa-solid fa-fire text-danger" style="color: #ff4757; text-shadow: 0 0 10px rgba(255, 71, 87, 0.4);"></i> {{ 'Popular Pokémon'|trans }}
		</h2>

		{% if trendingPokemons is empty %}
			<div class="empty-state card" style="text-align: center; padding: 40px; background-color: rgba(255, 255, 255, 0.02);">
				<p style="color: var(--text-muted); margin: 0;">{{ 'Nenhum Pokémon visitado ainda. Comece a explorar clicando na barra de busca acima!'|trans }}</p>
			</div>
		{% else %}
			<div class="pokemon-grid">
				{% for pokemon in trendingPokemons %}

					<a href="{{ path('app_pokemon_detail', { name: pokemon.name }) }}" class="pokemon-card">
						<div class="pokemon-card-bg-glow type-glow-{{ pokemon.types|first }}"></div>
						<div class="pokemon-moveset-count-badge">
							<i class="fa-solid fa-gamepad"></i>
							<span>{{ movesetCounts[pokemon.name|lower]|default(0) }} {{ (movesetCounts[pokemon.name|lower]|default(0) == 1 ? 'Moveset' : 'Movesets')|trans }}</span>
						</div>
						<span class="pokemon-id">#{{ "%03d"|format(pokemon.dex_id|default(pokemon.id)) }}</span>
						<div class="pokemon-sprite-container">
							<img src="{{ pokemon.sprite }}" alt="{{ pokemon.name|capitalize }}" class="pokemon-image" loading="lazy">
						</div>
						<h3 class="pokemon-name">{{ pokemon.name|abbr_pokemon_name }}</h3>
						<div class="pokemon-types">
							{% for type in pokemon.types %}
								{% include 'partials/type_badge.html.twig' with {'type': type, 'typeDetails': typeDetails} %}
							{% endfor %}
						</div>
					</a>

				{% endfor %}
			</div>
		{% endif %}
		
	</section>

	<!-- Sobre o Site & Sobre os Dados -->
	<section class="about-section">
		<div class="about-grid">
			<div class="about-card">
				<div class="about-card-glow color-primary-glow"></div>
				<div class="about-icon-wrapper">
					<i class="fa-solid fa-circle-info"></i>
				</div>
				<h2 class="about-title">{{ 'Sobre o Site'|trans }}</h2>
				<p class="about-desc">
					{{ 'O <strong>PokeFlaton</strong> é um portal completo criado para treinadores de Pokémon de todos os níveis. Nosso objetivo é fornecer uma plataforma amigável e intuitiva onde você pode explorar, criar e compartilhar os melhores <strong>movesets</strong>, combinações de itens, natures e habilidades recomendadas para cada Pokémon, ajudando você a montar a equipe perfeita para suas batalhas.'|trans|raw }}
				</p>
			</div>

			<div class="about-card">
				<div class="about-card-glow color-secondary-glow"></div>
				<div class="about-icon-wrapper secondary-icon">
					<i class="fa-solid fa-database"></i>
				</div>
				<h2 class="about-title">{{ 'Sobre os Dados'|trans }}</h2>
				<p class="about-desc">
					{{ 'Todas as informações exibidas no site incluindo nomes, tipos, status, habilidades, movimentos e imagens dos Pokémon são integradas de forma dinâmica e automatizada utilizando a <strong>PokeAPI</strong>, a API de dados pública mais robusta sobre o universo Pokémon. Dessa forma, garantimos dados confiáveis e sempre sincronizados com os jogos da franquia.'|trans|raw }}
				</p>
			</div>
		</div>
	</section>

	{% include 'partials/tooltip.html.twig' %}
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<div id="global-search-data" style="display: none;" data-url-search="{{ path('api_pokemon_search') }}"></div>
	<script src="{{ asset('js/pokemon-search.js') }}"></script>
{% endblock %}
