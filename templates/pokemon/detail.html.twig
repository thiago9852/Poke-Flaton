{% extends 'base.html.twig' %}

{% block title %}PokeFlaton |
	{{ pokemon.name|abbr_pokemon_name }}
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
	<link rel="stylesheet" href="{{ asset('css/pokemon.css') }}">
{% endblock %}

{% block body %}
	{% include 'partials/tooltip.html.twig' %}

	<!-- Pokémon Navigation Bar -->
	<div class="pokemon-navigation-bar">
		{% if prevPokemon %}

			<a href="{{ path('app_pokemon_detail', { name: prevPokemon.name }) }}" class="nav-button nav-prev type-hover-{{ prevPokemon.types|first }}">
				<span class="nav-arrow-circle">
					<i class="fa-solid fa-chevron-left"></i>
				</span>
				<div class="nav-text-container">
					<span class="nav-number">Nº {{ "%04d"|format(prevPokemon.species_id) }}</span>
					<span class="nav-name">{{ prevPokemon.name|abbr_pokemon_name }}</span>
				</div>
			</a>
			
		{% else %}
			<div class="nav-button nav-prev disabled"></div>
		{% endif %}

		{% if nextPokemon %}
			<a href="{{ path('app_pokemon_detail', { name: nextPokemon.name }) }}" class="nav-button nav-next type-hover-{{ nextPokemon.types|first }}">
				<div class="nav-text-container">
					<span class="nav-number">Nº {{ "%04d"|format(nextPokemon.species_id) }}</span>
					<span class="nav-name">{{ nextPokemon.name|abbr_pokemon_name }}</span>
				</div>
				<span class="nav-arrow-circle">
					<i class="fa-solid fa-chevron-right"></i>
				</span>
			</a>
		{% else %}
			<div class="nav-button nav-next disabled"></div>
		{% endif %}
	</div>

	<!-- Pokémon Header -->
	<div class="pokemon-current-header">
		<h1 class="current-title" style="margin: 0;">
			{{ pokemon.name|abbr_pokemon_name }}
			<span class="current-number">Nº
				{{ "%04d"|format(pokemon.species_id) }}
			</span>
		</h1>
	</div>

	<div
		class="pokemon-detail-layout">

		<!-- Coluna esquerda: Informações do Pokémon -->
		<div class="pokemon-info-column">
			{% include 'partials/pokemon_main_card.html.twig' with {'pokemon': pokemon, 'typeDetails': typeDetails} %}
			{% include 'partials/pokemon_stats_card.html.twig' with {'pokemon': pokemon} %}
			{% include 'partials/pokemon_locations_card.html.twig' with {'pokemon': pokemon, 'locations': locations} %}
		</div>

		<!-- Coluna direita: Seção de Movesets -->
		<div class="pokemon-movesets-column">

			<div class="movesets-header-container">
				<h2 class="section-column-title" style="margin: 0;">
					<i class="fa-solid fa-shield-halved"></i>
					{{ 'Melhores Movesets'|trans }}
				</h2>
				<a href="{{ path('app_moveset_new', { name: pokemon.name }) }}" class="btn btn-primary btn-icon">
					<i class="fa-solid fa-plus"></i>
					{{ 'Criar Moveset'|trans }}
				</a>
			</div>

			<!-- Abas de Navegação -->
			<div class="tabs-container">
				<button class="tab-btn active" onclick="switchTab(event, 'tab-padrao')">
					<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/poke-ball.png" style="width: 20px;">
					{{ 'PADRÃO'|trans }}
				</button>
				<button class="tab-btn" onclick="switchTab(event, 'tab-pvp')">
					<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/choice-scarf.png" style="width: 20px;">
					{{ 'PvP'|trans }}
				</button>
				<button class="tab-btn" onclick="switchTab(event, 'tab-dg')">
					<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/escape-rope.png" style="width: 20px;">
					{{ 'DG'|trans }}
				</button>
			</div>

			<!-- Conteúdo das Abas -->
			<div class="tabs-content-container">
				{% for tabType in ['padrao', 'pvp', 'dg'] %}
					<div id="tab-{{ tabType }}" class="tab-content {{ tabType == 'padrao' ? 'active' : '' }}">

						{% set defaultMoveset = null %}
						{% for m in movesets %}
							{% if m.type == tabType and m.isDefault %}
								{% set defaultMoveset = m %}
							{% endif %}
						{% endfor %}

						{% if defaultMoveset is null %}
							<div class="empty-moveset card" style="text-align: center; padding: 40px;">
								<h4>{{ 'Nenhum moveset padrão oficial definido para esta categoria'|trans }}</h4>
								<p class="text-muted" style="font-size: 0.9rem; margin-top: 5px;">{{ 'Sugira um moveset abaixo para que o administrador possa defini-lo como padrão.'|trans }}</p>
								<a href="{{ path('app_moveset_new', { name: pokemon.name }) }}" class="btn btn-secondary" style="margin-top: 10px;">
									{{ 'Criar / Sugerir Moveset'|trans }}
								</a>
							</div>
						{% else %}
							{% include 'partials/moveset_highlight_card.html.twig' with {
                                'm': defaultMoveset,
                                'moveDetails': moveDetails,
                                'pokemon': pokemon,
                                'itemDetails': itemDetails,
                                'naturesMap': naturesMap,
                                'abilityDetails': abilityDetails,
                                'recommendedNature': recommendedNatures[tabType],
                                'mostUsedNature': mostUsedNature,
                                'mostUsedNaturePercent': mostUsedNaturePercent
                            } %}
						{% endif %}

					</div>
				{% endfor %}
			</div>

			<!-- Outros Movesets Sugeridos -->
			<div class="all-movesets-container mt-5 mb-4">
				<h4 class="mb-3">{{ 'Outros Movesets Sugeridos'|trans }} ({{ movesets|length }})</h4>

				{% if movesets is empty %}
					<p class="text-muted">{{ 'Nenhum moveset sugerido ainda.'|trans }}</p>
				{% else %}
					<div class="moveset-list-column" style="display: flex; flex-direction: column; gap: 15px;">
						{% for m2 in movesets %}
							{% include 'partials/moveset_list_item.html.twig' with {
                                'm2': m2,
                                'pokemon': pokemon,
                                'moveDetails': moveDetails,
                                'itemDetails': itemDetails,
                                'naturesMap': naturesMap
                            } %}
						{% endfor %}
					</div>
				{% endif %}
			</div>

		</div>

	</div>

	<!-- Linha Evolutiva -->
	<div class="evolution-container mt-5">
		{% include 'partials/pokemon_evolution_card.html.twig' with {'pokemon': pokemon, 'evolutionChain': evolutionChain, 'typeDetails': typeDetails} %}
	</div>

	<!-- Cards de compartilhamento oculto -->
	<div style="position: absolute; left: -9999px; top: -9999px; overflow: hidden; width: 0; height: 0;">
		{% for m in movesets %}
			{% include 'partials/moveset_share_card.html.twig' with {
				'm': m,
				'pokemon': pokemon,
				'moveDetails': moveDetails,
				'itemDetails': itemDetails,
				'naturesMap': naturesMap,
				'abilityDetails': abilityDetails,
				'mostUsedNature': mostUsedNature,
				'mostUsedNaturePercent': mostUsedNaturePercent
			} %}
		{% endfor %}
	</div>

	<!-- Modal de prévia de compartilhamento -->
	<div id="share-modal" class="share-modal-overlay">
		<div class="share-modal-card">
			<div class="share-modal-header">
				<h3 class="share-modal-title">
					<i class="fa-solid fa-share-nodes"></i> {{ 'Compartilhar Moveset'|trans }}
				</h3>
				<button class="share-modal-close-btn" onclick="closeShareModal()">
					<i class="fa-solid fa-xmark"></i>
				</button>
			</div>
			
			<div class="share-modal-body">
				<!-- Loader Spinner -->
				<div id="share-modal-loader" class="share-modal-loader">
					<div class="share-modal-spinner"></div>
					<div class="share-modal-loader-text">{{ 'Gerando imagem em alta resolução...'|trans }}</div>
				</div>
				
				<!-- Imagem Preview -->
				<div id="share-modal-preview" class="share-modal-preview-container">
					<img id="share-modal-image" class="share-modal-preview-image" src="" alt="Preview">
				</div>
			</div>
			
			<div class="share-modal-footer">
				<button class="btn btn-secondary" onclick="closeShareModal()">{{ 'Fechar'|trans }}</button>
				<button id="share-modal-download-btn" class="btn btn-primary">
					<i class="fa-solid fa-download"></i> {{ 'Baixar PNG'|trans }}
				</button>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<!-- CDNs para html2canvas e qrcode-generator -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode-generator/1.4.4/qrcode.min.js"></script>

	<!-- Container Oculto com a URL via Twig para o JS -->
	<div id="pokemon-detail-data" style="display: none;"></div>

	<script src="{{ asset('js/detail.js') }}"></script>
{% endblock %}
