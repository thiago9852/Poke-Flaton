{% extends 'base.html.twig' %}

{% block title %}PokeFlaton - {{ pokemon.name|capitalize }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
    <link rel="stylesheet" href="{{ asset('css/pokemon.css') }}">
{% endblock %}

{% block body %}
    {% include 'partials/tooltip.html.twig' %}

    <!-- Pokémon Navigation Bar -->
    <div class="pokemon-navigation-bar">
        {% if prevPokemon %}
            <a href="{{ path('app_pokemon_detail', { name: prevPokemon.name }) }}" 
                class="nav-button nav-prev type-hover-{{ prevPokemon.types|first }}"
            >
                <span class="nav-arrow-circle"><i class="fa-solid fa-chevron-left"></i></span>
                <span class="nav-number">Nº {{ "%04d"|format(prevPokemon.id) }}</span>
                <span class="nav-name">{{ prevPokemon.name|capitalize }}</span>
            </a>
        {% else %}
            <div class="nav-button nav-prev disabled"></div>
        {% endif %}

        {% if nextPokemon %}
            <a href="{{ path('app_pokemon_detail', { name: nextPokemon.name }) }}" 
                class="nav-button nav-next type-hover-{{ nextPokemon.types|first }}"
            >
                <span class="nav-name">{{ nextPokemon.name|capitalize }}</span>
                <span class="nav-number">Nº {{ "%04d"|format(nextPokemon.id) }}</span>
                <span class="nav-arrow-circle"><i class="fa-solid fa-chevron-right"></i></span>
            </a>
        {% else %}
            <div class="nav-button nav-next disabled"></div>
        {% endif %}
    </div>

    <!-- Pokémon Header -->
    <div class="pokemon-current-header">
        <h1 class="current-title">
            {{ pokemon.name|capitalize }}
            <span class="current-number">Nº {{ "%04d"|format(pokemon.id) }}</span>
        </h1>
    </div>

    <div class="pokemon-detail-layout">
        
        <!-- Coluna esquerda: Informações do Pokémon -->
        <div class="pokemon-info-column">
            {% include 'partials/pokemon_main_card.html.twig' with {'pokemon': pokemon, 'typeDetails': typeDetails} %}
            {% include 'partials/pokemon_stats_card.html.twig' with {'pokemon': pokemon} %}
            {% include 'partials/pokemon_evolution_card.html.twig' with {'pokemon': pokemon, 'evolutionChain': evolutionChain, 'typeDetails': typeDetails} %}
        </div>

        <!-- Coluna direita: Seção de Movesets -->
        <div class="pokemon-movesets-column">
            
            <div class="movesets-header-container" 
                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;"
            >
                <h2 class="section-column-title" style="margin: 0;">
                    <i class="fa-solid fa-shield-halved"></i> Melhores Movesets
                </h2>
                <a href="{{ path('app_moveset_new', { name: pokemon.name }) }}" class="btn btn-primary btn-icon">
                    <i class="fa-solid fa-plus"></i> Criar Moveset
                </a>
            </div>

            <!-- Abas de Navegação -->
            <div class="tabs-container" style="display: flex; gap: 8px; border-bottom: 1px solid var(--border-color);">
                <button class="tab-btn active" data-tab="padrao" onclick="switchTab('padrao')" style="background: none; border: none; padding: 10px 20px; cursor: pointer; border-bottom: 2px solid var(--color-primary); color: var(--color-primary); font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/poke-ball.png" style="width: 20px;"> PADRÃO
                </button>
                <button class="tab-btn" data-tab="pvp" onclick="switchTab('pvp')" style="background: none; border: none; padding: 10px 20px; cursor: pointer; color: var(--text-secondary); font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/choice-scarf.png" style="width: 20px;"> PvP
                </button>
                <button class="tab-btn" data-tab="dg" onclick="switchTab('dg')" style="background: none; border: none; padding: 10px 20px; cursor: pointer; color: var(--text-secondary); font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/escape-rope.png" style="width: 20px;"> DG
                </button>
            </div>

            <!-- Conteúdo das Abas -->
            <div class="tabs-content-container">
                {% for tabType in ['padrao', 'pvp', 'dg'] %}
                    <div id="tab-{{ tabType }}" class="tab-content {{ tabType == 'padrao' ? 'active' : '' }}" 
                        style="display: {{ tabType == 'padrao' ? 'block' : 'none' }};"
                    >
                        
                        {% set typeMovesets = [] %}
                        {% for m in movesets %}
                            {% if m.type == tabType %}
                                {% set typeMovesets = typeMovesets|merge([m]) %}
                            {% endif %}
                        {% endfor %}

                        {% if typeMovesets is empty %}
                            <div class="empty-moveset card" style="text-align: center; padding: 40px;">
                                <i class="fa-solid fa-folder-open empty-moveset-icon" 
                                    style="font-size: 3em; color: #555; margin-bottom: 10px;"
                                ></i>

                                <h4>Nenhum moveset criado para esta categoria</h4>
                                <a href="{{ path('app_moveset_new', { name: pokemon.name }) }}" class="btn btn-secondary mt-3">
                                    Criar Agora
                                </a>
                            </div>
                        {% else %}
                            {% set m = typeMovesets|first %}
                            {% include 'partials/moveset_highlight_card.html.twig' with {
                                'm': m,
                                'moveDetails': moveDetails,
                                'pokemon': pokemon,
                                'itemDetails': itemDetails,
                                'naturesMap': naturesMap,
                                'abilityDetails': abilityDetails
                            } %}
                        {% endif %}

                    </div>
                {% endfor %}
            </div>

            <!-- Outros Movesets Sugeridos -->
            <div class="all-movesets-container mt-5 mb-4">
                <h4 class="mb-3">Outros Movesets Sugeridos ({{ movesets|length }})</h4>
                
                {% if movesets is empty %}
                    <p class="text-muted">Nenhum moveset sugerido ainda.</p>
                {% else %}
                    <div class="moveset-list-column" style="display: flex; flex-direction: column; gap: 15px;">
                        {% for m2 in movesets %}
                            {% include 'partials/moveset_list_item.html.twig' with {
                                'm2': m2,
                                'pokemon': pokemon,
                                'moveDetails': moveDetails,
                                'itemDetails': itemDetails
                            } %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            
        </div>
        
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(content => {
                content.style.display = 'none';
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
                btn.style.color = 'var(--text-secondary)';
                btn.style.borderBottomColor = 'transparent';
            });
            
            const targetContent = document.getElementById('tab-' + tabName);
            if (targetContent) {
                targetContent.style.display = 'block';
            }
            
            const activeBtn = document.querySelector(`[data-tab="${tabName}"]`);
            if (activeBtn) {
                activeBtn.classList.add('active');
                activeBtn.style.color = 'var(--color-primary)';
                activeBtn.style.borderBottomColor = 'var(--color-primary)';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const shinyToggle = document.getElementById('shiny-toggle');

            if (!shinyToggle) return;

            // Elementos da img
            const mainArtwork = document.getElementById('pokemon-artwork');

            // Elementos de stats
            const statValues = document.querySelectorAll('.stat-value');
            const statBars = document.querySelectorAll('.stat-bar-fill');

            // Constante max_stat usada no twig
            const MAX_STAT = 150;

            shinyToggle.addEventListener('click', function() {
                // Verifica se ta ativo/não
                const isShiny = shinyToggle.classList.toggle('active');

                // Controle estilo visual da estrela
                shinyToggle.style.opacity = isShiny ? '1' : '0.35';

                // troca sprite
                if (mainArtwork) {
                    mainArtwork.src = isShiny ? mainArtwork.dataset.shiny : mainArtwork.dataset.normal;
                }


                // Analisar base stats com buff de 50%
                statValues.forEach((span, index) => {
                    const baseVal = parseInt(span.dataset.baseVal, 10);

                    // Se for shiny
                    const newVal = isShiny ? Math.round(baseVal * 1.5) : baseVal;
                    span.textContent = newVal;

                    // Recupera a barra base e a barra do buff
                    const bar = statBars[index];
                    if (bar) {
                        const container = bar.parentElement;
                        const buffBar = container.querySelector('.stat-bar-buff');

                        if (isShiny) {
                            // Mantém a barra base com a largura original
                            bar.style.width = bar.dataset.basePercentage + '%';

                            // Calcula a largura da barra de buff (os 50% de ganho)
                            const basePercentage = parseFloat(bar.dataset.basePercentage);
                            let buffPercentage = ((newVal - baseVal) / MAX_STAT) * 100;

                            // Se a soma ultrapassar 100%, limita o buff para preencher o restante da barra
                            if (basePercentage + buffPercentage > 100) {
                                buffPercentage = 100 - basePercentage;
                            }

                            if (buffBar) {
                                buffBar.style.width = buffPercentage + '%';
                            }
                        } else {
                            // Restaura a barra base
                            bar.style.width = bar.dataset.basePercentage + '%';
                            if (buffBar) {
                                buffBar.style.width = '0%';
                            }
                        }
                    }
                });
            });
        });
    </script>
{% endblock %}