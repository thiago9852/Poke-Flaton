{% extends 'base.html.twig' %}

{% block title %}PokeFlaton |
	{{ pokemon.name|abbr_pokemon_name }}
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
	<link rel="stylesheet" href="{{ asset('css/pokemon.css') }}">
{% endblock %}

{% block body %}
	{% include 'partials/tooltip.html.twig' %}

	<!-- Botão Voltar -->
	<div class="stats-header-nav" style="margin-top: 15px;">
		<a href="{{ path('app_pokemon_index') }}" class="btn-back-game">
			<i class="fa-solid fa-arrow-left"></i> {{ 'Voltar'|trans }}
		</a>
	</div>

	<!-- Pokémon Navigation Bar -->
	<div class="pokemon-navigation-bar">
		{% if prevPokemon %}

			<a href="{{ path('app_pokemon_detail', { name: prevPokemon.name }) }}" class="nav-button nav-prev type-hover-{{ prevPokemon.types|first }}">
				<span class="nav-arrow-circle">
					<i class="fa-solid fa-chevron-left"></i>
				</span>
				<div class="nav-text-container">
					<span class="nav-number">Nº {{ "%04d"|format(prevPokemon.species_id) }}</span>
					<span class="nav-name">{{ prevPokemon.name|abbr_pokemon_name }}</span>
				</div>
			</a>
			
		{% else %}
			<div class="nav-button nav-prev disabled"></div>
		{% endif %}

		{% if nextPokemon %}
			<a href="{{ path('app_pokemon_detail', { name: nextPokemon.name }) }}" class="nav-button nav-next type-hover-{{ nextPokemon.types|first }}">
				<div class="nav-text-container">
					<span class="nav-number">Nº {{ "%04d"|format(nextPokemon.species_id) }}</span>
					<span class="nav-name">{{ nextPokemon.name|abbr_pokemon_name }}</span>
				</div>
				<span class="nav-arrow-circle">
					<i class="fa-solid fa-chevron-right"></i>
				</span>
			</a>
		{% else %}
			<div class="nav-button nav-next disabled"></div>
		{% endif %}
	</div>

	<!-- Pokémon Header -->
	<div class="pokemon-current-header">
		<h1 class="current-title" style="margin: 0;">
			{{ pokemon.name|abbr_pokemon_name }}
			<span class="current-number">Nº
				{{ "%04d"|format(pokemon.species_id) }}
			</span>
		</h1>
	</div>

	<div
		class="pokemon-detail-layout">

		<!-- Coluna esquerda: Informações do Pokémon -->
		<div class="pokemon-info-column">
			{% include 'partials/pokemon_main_card.html.twig' with {'pokemon': pokemon, 'typeDetails': typeDetails} %}
			{% include 'partials/pokemon_stats_card.html.twig' with {'pokemon': pokemon} %}
			{% include 'partials/pokemon_locations_card.html.twig' with {'pokemon': pokemon, 'locations': locations} %}
		</div>

		<!-- Coluna direita: Seção de Movesets -->
		<div class="pokemon-movesets-column">

			<div class="movesets-header-container">
				<h2 class="section-column-title" style="margin: 0;">
					<i class="fa-solid fa-shield-halved"></i>
					{{ 'Melhores Movesets'|trans }}
				</h2>
				<div style="display: flex; gap: 8px; flex-wrap: wrap;">
					<button class="btn btn-secondary btn-icon" onclick="openImportModal()" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-color); color: var(--text-secondary); cursor: pointer; padding: 12px 24px; border-radius: var(--radius-sm); font-weight: 600; font-family: inherit; font-size: 0.95rem; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
						<i class="fa-solid fa-file-import"></i>
						{{ 'Importar'|trans }}
					</button>
					<a href="{{ path('app_moveset_new', { name: pokemon.name }) }}" class="btn btn-primary btn-icon">
						<i class="fa-solid fa-plus"></i>
						{{ 'Criar Moveset'|trans }}
					</a>
				</div>
			</div>

			<!-- Abas de Navegação -->
			<div class="tabs-container">
				<button class="tab-btn active" onclick="switchTab(event, 'tab-padrao')">
					<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/poke-ball.png" style="width: 20px;">
					{{ 'PADRÃO'|trans }}
				</button>
				<button class="tab-btn" onclick="switchTab(event, 'tab-pvp')">
					<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/choice-scarf.png" style="width: 20px;">
					{{ 'PvP'|trans }}
				</button>
				<button class="tab-btn" onclick="switchTab(event, 'tab-dg')">
					<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/escape-rope.png" style="width: 20px;">
					{{ 'DG'|trans }}
				</button>
			</div>

			<!-- Conteúdo das Abas -->
			<div class="tabs-content-container">
				{% for tabType in ['padrao', 'pvp', 'dg'] %}
					<div id="tab-{{ tabType }}" class="tab-content {{ tabType == 'padrao' ? 'active' : '' }}">

						{% set defaultMoveset = null %}
						{% for m in movesets %}
							{% if m.type == tabType and m.isDefault %}
								{% set defaultMoveset = m %}
							{% endif %}
						{% endfor %}

						{% if defaultBaseMoves is not empty %}
							<div class="toggle-container" style="display: flex; justify-content: flex-end; margin-bottom: 12px;">
								<button class="btn btn-sm btn-outline-primary toggle-moves-btn" onclick="toggleDefaultMoves('{{ tabType }}')" style="padding: 6px 12px; font-size: 0.85rem; border-radius: 20px; border: 1px solid var(--color-primary); color: #fff; background: transparent; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; font-family: inherit;">
									<i class="fa-solid fa-sync"></i>
									<span class="toggle-text">
										{% if defaultMoveset is null %}
											{{ 'Mostrar Opção Criação'|trans }}
										{% else %}
											{{ 'Mostrar Opção Padrão '|trans }}
										{% endif %}
									</span>
								</button>
							</div>
						{% endif %}

						<!-- Bloco do Moveset do Banco / Formulário de Sugestão -->
						<div class="db-default-moveset-card {% if defaultMoveset is null %}empty-wrapper{% endif %}" id="db-default-{{ tabType }}" style="display: {{ (defaultMoveset is null and defaultBaseMoves is not empty) ? 'none' : 'block' }};">
							{% if defaultMoveset is null %}
								<div class="empty-moveset card" style="text-align: center; padding: 40px;">
									<h4>{{ 'Nenhum moveset padrão oficial definido para esta categoria'|trans }}</h4>
									<p class="text-muted" style="font-size: 0.9rem; margin-top: 5px;">{{ 'Sugira um moveset abaixo para que o administrador possa defini-lo como padrão.'|trans }}</p>
									<a href="{{ path('app_moveset_new', { name: pokemon.name }) }}" class="btn btn-secondary" style="margin-top: 10px;">
										{{ 'Criar / Sugerir Moveset'|trans }}
									</a>
								</div>
							{% else %}
								{% include 'partials/moveset_highlight_card.html.twig' with {
									'm': defaultMoveset,
									'moveDetails': moveDetails,
									'pokemon': pokemon,
									'itemDetails': itemDetails,
									'naturesMap': naturesMap,
									'abilityDetails': abilityDetails,
									'recommendedNature': recommendedNatures[tabType],
								} %}
							{% endif %}
						</div>

						<!-- Bloco do Moveset de Golpes Base JSON -->
						{% if defaultBaseMoves is not empty %}
							<div class="json-base-moveset-card" id="json-base-{{ tabType }}" style="display: {{ (defaultMoveset is null) ? 'block' : 'none' }};">
								<div class="moveset-card card moveset-highlight" style="padding: 20px;">
									<div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">
										<div style="display: flex; align-items: center; gap: 8px;">
											<h4 style="margin: 0; color: #fff; display: flex; align-items: center; gap: 8px; font-family: 'Outfit', sans-serif; font-weight: 800;">
												<i class="fa-solid fa-list-ol" style="color: var(--color-primary);"></i>
												{{ 'Golpes Base (Por Nível)'|trans }}
											</h4>
										</div>
									</div>
									
									<div class="moveset-grid" style="display: block;">
										<div class="moveset-section-moves" style="width: 100%;">
											<div class="moves-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px;">
												{% for moveName in defaultBaseMoves %}
													{% if moveName %}
														{% set md = moveDetails[moveName|lower] ?? null %}
														{% include 'partials/move_detail_item.html.twig' with {'moveName': moveName, 'md': md, 'pokemon': pokemon} %}
													{% endif %}
												{% endfor %}
											</div>
										</div>
									</div>
								</div>
							</div>
						{% endif %}
					</div>
				{% endfor %}
			</div>

			<!-- Outros Movesets Sugeridos -->
			<div class="all-movesets-container mt-5 mb-4">
				<h4 class="mb-3">{{ 'Outros Movesets Sugeridos'|trans }} ({{ movesets|length }})</h4>

				{% if movesets is empty %}
					<p class="text-muted">{{ 'Nenhum moveset sugerido ainda.'|trans }}</p>
				{% else %}
					<div class="moveset-list-column" style="display: flex; flex-direction: column; gap: 15px;">
						{% for m2 in movesets %}
							{% include 'partials/moveset_list_item.html.twig' with {
                                'm2': m2,
                                'pokemon': pokemon,
                                'moveDetails': moveDetails,
                                'itemDetails': itemDetails,
                                'naturesMap': naturesMap
                            } %}
						{% endfor %}
					</div>
				{% endif %}
			</div>

		</div>

	</div>

	<!-- Linha Evolutiva -->
	<div class="evolution-container mt-5">
		{% include 'partials/pokemon_evolution_card.html.twig' with {'pokemon': pokemon, 'evolutionChain': evolutionChain, 'typeDetails': typeDetails} %}
	</div>

	<!-- Cards de compartilhamento oculto -->
	<div style="position: absolute; left: -9999px; top: -9999px; overflow: hidden; width: 0; height: 0;">
		{% for m in movesets %}
			{% include 'partials/moveset_share_card.html.twig' with {
				'm': m,
				'pokemon': pokemon,
				'moveDetails': moveDetails,
				'itemDetails': itemDetails,
				'naturesMap': naturesMap,
				'abilityDetails': abilityDetails,
				'mostUsedNature': mostUsedNature,
				'mostUsedNaturePercent': mostUsedNaturePercent
			} %}
		{% endfor %}
	</div>

	<!-- Modal de prévia de compartilhamento -->
	<div id="share-modal" class="share-modal-overlay">
		<div class="share-modal-card">
			<div class="share-modal-header">
				<h3 class="share-modal-title">
					<i class="fa-solid fa-share-nodes"></i> {{ 'Compartilhar Moveset'|trans }}
				</h3>
				<button class="share-modal-close-btn" onclick="closeShareModal()">
					<i class="fa-solid fa-xmark"></i>
				</button>
			</div>
			
			<div class="share-modal-body">
				<!-- Loader Spinner -->
				<div id="share-modal-loader" class="share-modal-loader">
					<div class="share-modal-spinner"></div>
					<div class="share-modal-loader-text">{{ 'Gerando imagem em alta resolução...'|trans }}</div>
				</div>
				
				<!-- Imagem Preview -->
				<div id="share-modal-preview" class="share-modal-preview-container">
					<img id="share-modal-image" class="share-modal-preview-image" src="" alt="Preview">
				</div>
			</div>
			
			<div class="share-modal-footer">
				<button class="btn btn-secondary" onclick="closeShareModal()">{{ 'Fechar'|trans }}</button>
				<button id="share-modal-download-btn" class="btn btn-primary">
					<i class="fa-solid fa-download"></i> {{ 'Baixar PNG'|trans }}
				</button>
			</div>
		</div>
	</div>

	<!-- Modal de Importação -->
	<div id="import-modal" class="share-modal-overlay">
		<div class="share-modal-card" style="max-width: 500px;">
			<div class="share-modal-header">
				<h3 class="share-modal-title">
					<i class="fa-solid fa-file-import"></i> {{ 'Importar Moveset'|trans }}
				</h3>
				<button class="share-modal-close-btn" onclick="closeImportModal()">
					<i class="fa-solid fa-xmark"></i>
				</button>
			</div>
			
			<div class="share-modal-body" style="padding: 20px; display: flex; flex-direction: column; gap: 15px;">
				<p style="font-size: 0.9rem; color: var(--text-secondary); margin: 0;">
					{{ 'Você pode carregar um arquivo .json ou colar o conteúdo JSON abaixo para preencher o moveset.'|trans }}
				</p>
				
				<div class="form-group" style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
					<label for="import-file" class="form-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">{{ 'Carregar arquivo .json'|trans }}</label>
					<input type="file" id="import-file" accept=".json" class="form-input" style="width: 100%; box-sizing: border-box; padding: 8px; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: var(--radius-sm); color: var(--text-primary);">
				</div>
				
				<div style="text-align: center; color: var(--text-muted); font-size: 0.8rem; margin: 5px 0;">-- {{ 'OU'|trans }} --</div>
				
				<div class="form-group" style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
					<label for="import-text" class="form-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">{{ 'Colar texto JSON'|trans }}</label>
					<textarea id="import-text" rows="6" class="form-input" style="width: 100%; box-sizing: border-box; font-family: monospace; font-size: 0.85rem; resize: vertical; padding: 12px 16px; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: var(--radius-sm); color: var(--text-primary);" placeholder='{&#10;  "pokemonName": "charizard",&#10;  "type": "padrao",&#10;  "ability": "blaze",&#10;  "nature": "jolly",&#10;  "heldItem": "charizardite-y",&#10;  "moves": ["flamethrower", "solar-beam", "roost", "focus-blast"]&#10;}'></textarea>
				</div>
			</div>
			
			<div class="share-modal-footer">
				<button class="btn btn-secondary" onclick="closeImportModal()">{{ 'Cancelar'|trans }}</button>
				<button id="import-submit-btn" class="btn btn-primary" onclick="handleImportSubmit()">
					<i class="fa-solid fa-check"></i> {{ 'Importar'|trans }}
				</button>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<!-- CDNs para html2canvas e qrcode-generator -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode-generator/1.4.4/qrcode.min.js"></script>

	<!-- Container Oculto com a URL via Twig para o JS -->
	<div id="pokemon-detail-data" style="display: none;"></div>

	<script src="{{ asset('js/detail.js') }}?v=1.0.1"></script>
	<script>
		function toggleDefaultMoves(tabType) {
			const dbCard = document.getElementById('db-default-' + tabType);
			const jsonCard = document.getElementById('json-base-' + tabType);
			const btn = document.querySelector(`.toggle-moves-btn[onclick*="${tabType}"]`);
			if (dbCard && jsonCard && btn) {
				const isDbHidden = dbCard.style.display === 'none';
				if (isDbHidden) {
					dbCard.style.display = 'block';
					jsonCard.style.display = 'none';
					btn.querySelector('.toggle-text').textContent = '{{ "Mostrar Golpes Padrão (Base)"|trans }}';
				} else {
					dbCard.style.display = 'none';
					jsonCard.style.display = 'block';
					btn.querySelector('.toggle-text').textContent = dbCard.classList.contains('empty-wrapper') 
						? '{{ "Mostrar Opções de Criação"|trans }}' 
						: '{{ "Mostrar Moveset Recomendado"|trans }}';
				}
			}
		}
	</script>
{% endblock %}
