{% extends 'base.html.twig' %}

{% block title %}
	{{ tierList.title }} | PokeFlaton
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/tier-list.css') }}">
{% endblock %}

{% block body %}
	<div class="tier-list-container">
		<!-- Meta details -->
		<section class="viewer-meta-container">
			<div class="viewer-info-block">
				<h1 class="viewer-title">{{ tierList.title }}</h1>
				<div class="viewer-details">
					<span>
						<i class="fa-solid fa-user"></i>
						{{ 'Publicada por'|trans }}
						<strong>{{ tierList.user ? tierList.user.username : 'Anônimo'|trans }}</strong>
					</span>
					<span>&bull;</span>
					<span>
						<i class="fa-solid fa-calendar-days"></i>
						{{ tierList.createdAt|date('d/m/Y H:i') }}
					</span>
				</div>
				<div class="viewer-tags">
					{% for tag in tierList.tags %}
						{% if tag == 'up' %}
							<span class="tag-badge tag-badge-up"><i class="fa-solid fa-circle-arrow-up"></i> {{ 'PVE'|trans }}</span>
						{% elseif tag == 'pvp' %}
							<span class="tag-badge tag-badge-pvp"><i class="fa-solid fa-trophy"></i> {{ 'PVP'|trans }}</span>
						{% elseif tag == 'dg' %}
							<span class="tag-badge tag-badge-dg"><i class="fa-solid fa-shield-halved"></i> {{ 'Dungeons'|trans }}</span>
						{% elseif tag == 'fun' %}
							<span class="tag-badge tag-badge-fun"><i class="fa-solid fa-star"></i> {{ 'Fun'|trans }}</span>
						{% endif %}
					{% endfor %}
				</div>
			</div>

			<!-- Action buttons -->
			<div class="action-buttons-group">
				<a href="{{ path('app_tier_list_create', { clone: tierList.id }) }}" class="btn-tier btn-tier-export" style="text-decoration: none;">
					<i class="fa-solid fa-clone"></i>
					<span>{{ 'Clonar & Editar'|trans }}</span>
				</a>
				<button class="btn-tier btn-tier-share" id="btnExport" title="{{ 'Exportar Imagem'|trans }}">
					<i class="fa-solid fa-download"></i>
					<span>{{ 'Exportar Imagem'|trans }}</span>
				</button>
				{% if canDelete %}
					<form action="{{ path('app_tier_list_delete', { id: tierList.id }) }}" method="POST" style="display: inline;" onsubmit="return confirm('{{ 'Tem certeza de que deseja excluir permanentemente esta Tier List?'|trans }}');">
						<input type="hidden" name="_token" value="{{ csrf_token('delete-tier-list-' ~ tierList.id) }}">
						<button type="submit" class="btn-tier btn-tier-danger" style="border: none;">
							<i class="fa-solid fa-trash-can"></i>
							<span>{{ 'Excluir'|trans }}</span>
						</button>
					</form>
				{% endif %}
				<a href="{{ path('app_tier_list') }}" class="btn-tier btn-tier-secondary" style="text-decoration: none;">
					<i class="fa-solid fa-arrow-left"></i>
					<span>{{ 'Voltar'|trans }}</span>
				</a>
			</div>
		</section>

		<!-- Tier Board Read Only -->
		<section class="tier-board tier-board-viewonly" id="tierBoard">
			{% for tier in tierList.state %}
				<div class="tier-row" style="border-bottom: 2px solid var(--border-color);">
					<!-- Label (Contrast set via JS on page load) -->
					<div class="tier-label-col" style="background-color: {{ tier.color }}; cursor: default;">
						<span class="tier-label-text">{{ tier.label }}</span>
					</div>

					<!-- Content -->
					<div class="tier-content-col">
						{% for pokeId in tier.pokemons %}
							{% if pokemonMap[pokeId] is defined %}
								{% set p = pokemonMap[pokeId] %}
								<div class="tier-pokemon-card" data-name="{{ p.name|capitalize }}" title="{{ p.name|capitalize }}">
									<img src="{{ p.sprite }}" alt="{{ p.name }}">
								</div>
							{% endif %}
						{% endfor %}
					</div>
				</div>
			{% endfor %}
		</section>
	</div>

	<!-- Toast -->
	<div class="tier-toast" id="tierToast">
		<i class="fa-solid fa-circle-check"></i>
		<span id="toastMessage">{{ 'Gerando imagem do tier list...'|trans }}</span>
	</div>

	<!-- html2canvas dependência -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

	<!-- Embedded capture script for read-only viewer -->
	<script>
		document.addEventListener('turbo:load', () => {
			const btnExport = document.getElementById('btnExport');
			const tierToast = document.getElementById('tierToast');
			const toastMessage = document.getElementById('toastMessage');

			function showToast(message) {
				toastMessage.textContent = message;
				tierToast.classList.add('show');
				setTimeout(() => {
					tierToast.classList.remove('show');
				}, 3000);
			}

			// Contrast Helper for Text Color over Tier Background Colors
			function getContrastColor(hexColor) {
				const r = parseInt(hexColor.slice(1, 3), 16);
				const g = parseInt(hexColor.slice(3, 5), 16);
				const b = parseInt(hexColor.slice(5, 7), 16);
				const yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
				return (yiq >= 128) ? '#11131a' : '#ffffff';
			}

			// Convert rgb(r, g, b) string to Hex
			function rgbToHex(rgb) {
				if (rgb.startsWith('#')) return rgb;
				const rgbValues = rgb.replace(/[^\d,]/g, '').split(',');
				if (rgbValues.length < 3) return '#9e9e9e';
				const r = parseInt(rgbValues[0]);
				const g = parseInt(rgbValues[1]);
				const b = parseInt(rgbValues[2]);
				return "#" + ((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1);
			}

			// Recalculate labels contrast colors
			document.querySelectorAll('.tier-label-col').forEach(label => {
				const bg = window.getComputedStyle(label).backgroundColor;
				const hex = rgbToHex(bg);
				label.style.color = getContrastColor(hex);
			});

			btnExport.addEventListener('click', () => {
				showToast("{{ 'Gerando imagem do tier list...'|trans }}");

				const board = document.getElementById('tierBoard');
				
				html2canvas(board, {
					useCORS: true,
					backgroundColor: '#090a0f',
					scale: 2
				}).then(canvas => {
					const link = document.createElement('a');
					link.download = 'pokeflaton-tier-list.png';
					link.href = canvas.toDataURL('image/png');
					link.click();
					showToast("{{ 'Download da imagem iniciado!'|trans }}");
				}).catch(err => {
					console.error("Erro ao exportar imagem:", err);
					showToast("{{ 'Falha ao gerar imagem da Tier List!'|trans }}");
				});
			});
		});
	</script>
{% endblock %}
