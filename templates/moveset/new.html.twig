{% extends 'base.html.twig' %}

{% block title %}Moveset |
	{{ pokemon.name|capitalize }}
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
	<link rel="stylesheet" href="{{ asset('css/pokemon.css') }}">
{% endblock %}

{% block body %}
	<div class="back-link-container">
		<a href="{{ path('app_pokemon_detail', { name: pokemon.name }) }}" class="back-link">
			<i class="fa-solid fa-arrow-left"></i>
			{{ 'Voltar para'|trans }}
			{{ pokemon.name|capitalize }}
		</a>
	</div>


	<form action="{{ path('app_moveset_new', { name: pokemon.name }) }}" method="POST" class="moveset-form-wrapper">

		{% if errors is not empty %}
			<div class="alert alert-error">
				<ul class="errors-list">
					{% for error in errors %}
						<li>
							<i class="fa-solid fa-circle-exclamation"></i>
							{{ error|trans }}</li>
					{% endfor %}
				</ul>
			</div>
		{% endif %}

		<!-- TOPO: Card do Pokémon + Campos de Build -->
		<div
			class="moveset-top-layout">

			<!-- Card do Pokémon -->
			<div class="pokemon-summary-card card">

				<div class="detail-glow type-glow-{{ pokemon.types|first }}"></div>
				<div class="summary-sprite-container">
					<img src="{{ pokemon.sprite_official }}" alt="{{ pokemon.name|capitalize }}" class="summary-artwork">
				</div>

				<h2 class="summary-name">{{ pokemon.name|capitalize }}</h2>
				<div class="summary-types">
					{% for type in pokemon.types %}
						<span class="type-badge type-badge-{{ type }}">{{ type|capitalize|trans }}</span>
					{% endfor %}
				</div>

				<div class="summary-quick-stats">
					<div class="quick-stat-item">
						<span class="label">S.ATK</span>
						<span class="value">{{ pokemon.stats['special-attack'] }}</span>
					</div>
					<div class="quick-stat-item">
						<span class="label">ATK</span>
						<span class="value">{{ pokemon.stats.attack }}</span>
					</div>
					<div class="quick-stat-item">
						<span class="label">DEF</span>
						<span class="value">{{ pokemon.stats.defense }}</span>
					</div>
					<div class="quick-stat-item">
						<span class="label">S.DEF</span>
						<span class="value">{{ pokemon.stats['special-defense'] }}</span>
					</div>
				</div>

			</div>

			<!-- Campos de Build -->
			<div class="moveset-build-fields card">
				<h1 class="form-page-title">{{ 'Criar Novo Moveset'|trans }}</h1>

				<!-- Tipo de Moveset -->
				<div class="form-group">
					<label class="form-label">{{ 'Tipo de Moveset'|trans }}</label>
					<div class="radio-group-cards">

						<label class="radio-card">
							<input type="radio" name="type" value="padrao" checked>
							<div class="radio-card-content">
								<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/poke-ball.png" alt="Poke Ball" class="radio-card-sprite" title="{{ 'Padrão'|trans }}">
								<span class="title">{{ 'Padrão'|trans }}</span>
							</div>
						</label>

						<label class="radio-card">
							<input type="radio" name="type" value="pvp">
							<div class="radio-card-content">
								<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/choice-scarf.png" alt="Choice Band" class="radio-card-sprite" title="PvP">
								<span class="title">PvP</span>
							</div>
						</label>

						<label class="radio-card">
							<input type="radio" name="type" value="dg">
							<div class="radio-card-content">
								<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/escape-rope.png" alt="Escape Rope" class="radio-card-sprite" title="Dungeon">
								<span class="title">{{ 'Dungeon'|trans }}</span>
							</div>
						</label>

					</div>
				</div>

				<!-- Habilidade, Nature e Held Item -->
				<div class="form-row">

					<div class="form-group half-width">
						<label for="ability" class="form-label">{{ 'Habilidade (Opcional)'|trans }}</label>
						<select name="ability" id="ability" class="form-select">
							<option value="">{{ '-- Escolha a Habilidade --'|trans }}</option>
							{% for ab in pokemon.abilities %}
								<option value="{{ ab }}">{{ ab|replace({'-': ' '})|title }}</option>
							{% endfor %}
						</select>
					</div>

					<div class="form-group half-width">
						<label for="nature" class="form-label">{{ 'Nature'|trans }}</label>
						<select name="nature" id="nature" class="form-select" required>
							<option value="">{{ '-- Selecione a Nature --'|trans }}</option>

							{% for n in natures %}
								<option value="{{ n.name }}">
									{{ n.name|capitalize|trans }}
									{% if n.increased != 'none' or n.decreased != 'none' %}
										(+{{ (n.increased|replace({'-': ' '})|title)|trans }}, -{{ (n.decreased|replace({'-': ' '})|title)|trans }})
									{% else %}
										({{ 'Neutra'|trans }})
									{% endif %}
								</option>
							{% endfor %}

						</select>
					</div>

					<div class="form-group half-width">
						<label for="heldItemInput" class="form-label">{{ 'Item Segurado (Opcional)'|trans }}</label>
						<input type="text" id="heldItemInput" name="heldItem" list="items-list" class="form-input" placeholder="{{ 'Digite para buscar...'|trans }}" autocomplete="off">
						<datalist id="items-list">
							{% for item in items %}
								<option value="{{ item.name }}">{{ item.name|replace({'-': ' '})|title }}</option>
							{% endfor %}
						</datalist>
					</div>

				</div>

			</div>
		</div>

		<!-- Largura Total: Seleção de Movimentos -->
		<div class="moveset-moves-fullwidth card">
			<div class="moves-fullwidth-header">
				<span class="form-label">
					{{ 'Movimentos Selecionados'|trans }}
					<span class="slots-counter" id="slots-counter">(0 /
						{{ maxMoves }})</span>
				</span>
			</div>

			<!-- Slots 5×2 -->
			<div class="selected-slots-section">
				<div
					class="selected-slots-list" id="selected-slots-list"><!-- Inserido dinamicamente via JS -->
				</div>

				<!-- Inputs Ocultos -->
				<div id="hidden-inputs-container">
					{% for i in 1..maxMoves %}
						<input type="hidden" name="move{{ i }}" id="hidden-move-{{ i }}" value="">
					{% endfor %}
				</div>

			</div>

			<!-- Pesquisa + Filtros -->
			<div class="search-filter-row">
				<div class="search-box">
					<input type="text" id="available-moves-search" class="search-input" placeholder="{{ 'Buscar golpe por nome...'|trans }}">
					<i class="fa-solid fa-magnifying-glass search-icon"></i>
				</div>
				<div class="filter-buttons">
					<button type="button" class="btn-filter active" data-filter="all">
						<i class="fa-solid fa-layer-group"></i>
						{{ 'Todos'|trans }}</button>
					<button type="button" class="btn-filter" data-filter="lvl">
						<i class="fa-solid fa-circle-chevron-up"></i>
						Lvl</button>
					<button type="button" class="btn-filter" data-filter="tm">
						<i class="fa-solid fa-compact-disc"></i>
						TM</button>
				</div>
			</div>

			{% if pokemon.name|lower == 'smeargle' %}
				<!-- Adicionar golpe personalizado para Smeargle -->
				<div class="custom-move-row" style="margin-top: 15px; margin-bottom: 15px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
					<div class="search-box" style="flex: 1; min-width: 250px; position: relative; display: flex; align-items: center; margin: 0;">
						<input type="text" id="custom-move-input" class="search-input" style="width: 100%; padding-left: 42px;" placeholder="{{ 'Digitar qualquer outro golpe em inglês (ex: Spore, V-create)...'|trans }}">
						<i class="fa-solid fa-wand-magic-sparkles search-icon" style="position: absolute; left: 14px; color: var(--color-primary); font-size: 0.95rem;"></i>
					</div>
					<button type="button" class="btn btn-primary" id="add-custom-move-btn" style="padding: 12px 24px; height: 42px; display: inline-flex; align-items: center; gap: 8px;">
						<i class="fa-solid fa-plus"></i>
						{{ 'Adicionar'|trans }}
					</button>
				</div>
			{% endif %}

			<!-- Lista de Golpes Disponíveis -->
			<!-- Tooltip flutuante -->
			{% include 'partials/tooltip.html.twig' %}

			{% set movesList = pokemon.moves %}
			{% if pokemon.name|lower == 'smeargle' and allTms is defined and allTms is not empty %}
				{% set tmNames = [] %}
				{% for mv in pokemon.moves %}
					{% set tmNames = tmNames|merge([mv.name is defined ? mv.name : mv]) %}
				{% endfor %}
				{% for tm in allTms %}
					{% if tm.move not in tmNames %}
						{% set movesList = movesList|merge([{ 'name': tm.move, 'learn_method': 'TM' }]) %}
					{% endif %}
				{% endfor %}
			{% endif %}

			<div class="available-moves-list" id="available-moves-list">
				{% for move in movesList %}

					{% set moveName = move.name is defined ? move.name : move %}
					{% set learnMethod = move.learn_method is defined ? move.learn_method : 'base' %}

					{% set isLocked = false %}
					{% if app.user and learnMethod == 'TM' and moveName not in unlockedTms and pokemon.name|lower != 'smeargle' %}
						{% set isLocked = true %}
					{% endif %}

					<div class="available-move-card {% if isLocked %}move-locked{% endif %}" data-move-name="{{ moveName }}" data-learn-method="{{ learnMethod }}" data-locked="{% if isLocked %}true{% else %}false{% endif %}" onclick="{% if isLocked %}alert('{{ 'Você precisa desbloquear a'|trans }} {{ moveName|replace({'-': ' '})|title }} (TM) {{ 'no seu Trainer Card para poder usá-la!'|trans }}');{% else %}addMoveToFirstEmptySlot('{{ moveName }}'){% endif %}" onmouseenter="showMoveTooltip(event, '{{ moveName }}')" onmouseleave="hideMoveTooltip()">
						<span class="move-name">
							{% if isLocked %}
								<i class="fa-solid fa-lock" style="color: #ef4444; margin-right: 6px;" title="TM Bloqueada"></i>
							{% endif %}
							{{ moveName|replace({'-': ' '})|title }}
						</span>
						<div class="move-badges">

							{% if learnMethod == 'both' %}
								<span class="learn-method-badge method-base">Lvl</span>
								<span class="learn-method-badge method-tm">TM</span>
							{% elseif learnMethod == 'TM' %}
								<span class="learn-method-badge method-tm">TM</span>
							{% else %}
								<span class="learn-method-badge method-base">Lvl</span>
							{% endif %}

							<span class="type-badge-sm type-badge-pr type-badge-loading"></span>
						</div>
					</div>

				{% endfor %}
			</div>
		</div>

		<!-- Ações abaixo dos moves -->
		<div class="moveset-bottom-section card">
			<div class="form-actions" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
				<button type="button" class="btn btn-secondary btn-icon" onclick="openImportModal()" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-color); color: var(--text-secondary); cursor: pointer; padding: 12px 24px; border-radius: var(--radius-sm); font-weight: 600; font-family: inherit; font-size: 0.95rem; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
					<i class="fa-solid fa-file-import"></i>
					{{ 'Importar JSON'|trans }}
				</button>
				<a href="{{ path('app_pokemon_detail', { name: pokemon.name }) }}" class="btn btn-secondary">{{ 'Cancelar'|trans }}</a>
				<button type="submit" name="action" value="save" class="btn btn-secondary" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-color); color: var(--text-secondary);">
					<i class="fa-solid fa-floppy-disk"></i>
					{{ 'Salvar'|trans }}
				</button>
				<button type="submit" name="action" value="suggest" class="btn btn-primary">
					<i class="fa-solid fa-star"></i>
					{{ 'Salvar e Sugerir'|trans }}
				</button>
			</div>
		</div>

	</form>

	<!-- Modal de Importação -->
	<div id="import-modal" class="share-modal-overlay">
		<div class="share-modal-card" style="max-width: 500px;">
			<div class="share-modal-header">
				<h3 class="share-modal-title">
					<i class="fa-solid fa-file-import"></i> {{ 'Importar Moveset'|trans }}
				</h3>
				<button class="share-modal-close-btn" onclick="closeImportModal()">
					<i class="fa-solid fa-xmark"></i>
				</button>
			</div>
			
			<div class="share-modal-body" style="padding: 20px; display: flex; flex-direction: column; gap: 15px;">
				<p style="font-size: 0.9rem; color: var(--text-secondary); margin: 0;">
					{{ 'Você pode carregar um arquivo .json ou colar o conteúdo JSON abaixo para preencher o moveset.'|trans }}
				</p>
				
				<div class="form-group" style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
					<label for="import-file" class="form-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">{{ 'Carregar arquivo .json'|trans }}</label>
					<input type="file" id="import-file" accept=".json" class="form-input" style="width: 100%; box-sizing: border-box; padding: 8px; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: var(--radius-sm); color: var(--text-primary);">
				</div>
				
				<div style="text-align: center; color: var(--text-muted); font-size: 0.8rem; margin: 5px 0;">-- {{ 'OU'|trans }} --</div>
				
				<div class="form-group" style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
					<label for="import-text" class="form-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">{{ 'Colar texto JSON'|trans }}</label>
					<textarea id="import-text" rows="6" class="form-input" style="width: 100%; box-sizing: border-box; font-family: monospace; font-size: 0.85rem; resize: vertical; padding: 12px 16px; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: var(--radius-sm); color: var(--text-primary);" placeholder='{&#10;  "pokemonName": "charizard",&#10;  "type": "padrao",&#10;  "ability": "blaze",&#10;  "nature": "jolly",&#10;  "heldItem": "charizardite-y",&#10;  "moves": ["flamethrower", "solar-beam", "roost", "focus-blast"]&#10;}'></textarea>
				</div>
			</div>
			
			<div class="share-modal-footer">
				<button class="btn btn-secondary" onclick="closeImportModal()">{{ 'Cancelar'|trans }}</button>
				<button id="import-submit-btn" class="btn btn-primary" onclick="handleImportSubmit()">
					<i class="fa-solid fa-check"></i> {{ 'Importar'|trans }}
				</button>
			</div>
		</div>
	</div>

	<!-- Container Oculto para passar dados do Twig para o JS externo -->
	<div id="moveset-app-data" data-max-moves="{{ maxMoves }}" data-locale="{{ app.request.locale }}" style="display: none;"></div>

	<script src="{{ asset('js/create-moves.js') }}"></script>
{% endblock %}
