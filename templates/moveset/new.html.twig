{% extends 'base.html.twig' %}

{% block title %}Moveset | {{ pokemon.name|capitalize }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
    <link rel="stylesheet" href="{{ asset('css/pokemon.css') }}">
{% endblock %}

{% block body %}
<div class="back-link-container">
    <a href="{{ path('app_pokemon_detail', { name: pokemon.name }) }}" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Voltar para {{ pokemon.name|capitalize }}
    </a>
</div>


<form action="{{ path('app_moveset_new', { name: pokemon.name }) }}" method="POST" class="moveset-form-wrapper">

    {% if errors is not empty %}
        <div class="alert alert-error">
            <ul class="errors-list">
                {% for error in errors %}
                    <li><i class="fa-solid fa-circle-exclamation"></i> {{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <!-- TOPO: Card do Pokémon + Campos de Build -->
    <div class="moveset-top-layout">

        <!-- Card do Pokémon -->
        <div class="pokemon-summary-card card">

            <div class="detail-glow type-glow-{{ pokemon.types|first }}"></div>
            <div class="summary-sprite-container">
                <img src="{{ pokemon.sprite_official }}" alt="{{ pokemon.name|capitalize }}" class="summary-artwork">
            </div>

            <h2 class="summary-name">{{ pokemon.name|capitalize }}</h2>
            <div class="summary-types">
                {% for type in pokemon.types %}
                    <span class="type-badge type-badge-{{ type }}">{{ type|capitalize }}</span>
                {% endfor %}
            </div>

            <div class="summary-quick-stats">
                <div class="quick-stat-item">
                    <span class="label">HP</span>
                    <span class="value">{{ pokemon.stats.hp }}</span>
                </div>
                <div class="quick-stat-item">
                    <span class="label">ATK</span>
                    <span class="value">{{ pokemon.stats.attack }}</span>
                </div>
                <div class="quick-stat-item">
                    <span class="label">DEF</span>
                    <span class="value">{{ pokemon.stats.defense }}</span>
                </div>
            </div>

        </div>

        <!-- Campos de Build -->
        <div class="moveset-build-fields card">
            <h1 class="form-page-title">Criar Novo Moveset</h1>

            <!-- Tipo de Moveset -->
            <div class="form-group">
                <label class="form-label">Tipo de Moveset</label>
                <div class="radio-group-cards">

                    <label class="radio-card">
                        <input type="radio" name="type" value="padrao" checked>
                        <div class="radio-card-content">
                            <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/poke-ball.png" alt="Poke Ball" class="radio-card-sprite" title="Padrão">
                            <span class="title">Padrão</span>
                        </div>
                    </label>

                    <label class="radio-card">
                        <input type="radio" name="type" value="pvp">
                        <div class="radio-card-content">
                            <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/choice-scarf.png" alt="Choice Band" class="radio-card-sprite" title="PvP">
                            <span class="title">PvP</span>
                        </div>
                    </label>

                    <label class="radio-card">
                        <input type="radio" name="type" value="dg">
                        <div class="radio-card-content">
                            <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/escape-rope.png" alt="Escape Rope" class="radio-card-sprite" title="Dungeon">
                            <span class="title">Dungeon</span>
                        </div>
                    </label>

                </div>
            </div>

            <!-- Habilidade, Nature e Held Item -->
            <div class="form-row">

                <div class="form-group half-width">
                    <label for="ability" class="form-label">Habilidade</label>
                    <select name="ability" id="ability" class="form-select" required>
                        <option value="">-- Escolha a Habilidade --</option>
                        {% for ab in pokemon.abilities %}
                            <option value="{{ ab }}">{{ ab|replace({'-': ' '})|title }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group half-width">
                    <label for="nature" class="form-label">Nature</label>
                    <select name="nature" id="nature" class="form-select" required>
                        <option value="">-- Selecione a Nature --</option>

                        {% for n in natures %}
                            <option value="{{ n.name }}">
                                {{ n.name|capitalize }}
                                {% if n.increased != 'none' or n.decreased != 'none' %}
                                    (+{{ n.increased|replace({'-': ' '})|title }}, -{{ n.decreased|replace({'-': ' '})|title }})
                                {% else %}
                                    (Neutra)
                                {% endif %}
                            </option>
                        {% endfor %}

                    </select>
                </div>

                <div class="form-group half-width">
                    <label for="heldItemInput" class="form-label">Item Segurado</label>
                    <input type="text" id="heldItemInput" name="heldItem" list="items-list" 
                        class="form-input" placeholder="Digite para buscar..." required autocomplete="off"
                    >
                    <datalist id="items-list">
                        {% for item in items %}
                            <option value="{{ item.name }}">{{ item.name|replace({'-': ' '})|title }}</option>
                        {% endfor %}
                    </datalist>
                </div>

            </div>

        </div>
    </div>

    <!-- Largura Total: Seleção de Movimentos -->
    <div class="moveset-moves-fullwidth card">
        <div class="moves-fullwidth-header">
            <span class="form-label">
                Movimentos Selecionados 
                <span class="slots-counter" id="slots-counter">(0 / {{ maxMoves }})</span>
            </span>
        </div>

        <!-- Slots 5×2 -->
        <div class="selected-slots-section">
            <div class="selected-slots-list" id="selected-slots-list">
                <!-- Inserido dinamicamente via JS -->
            </div>

            <!-- Inputs Ocultos -->
            <div id="hidden-inputs-container">
                {% for i in 1..maxMoves %}
                    <input type="hidden" name="move{{ i }}" id="hidden-move-{{ i }}" value="">
                {% endfor %}
            </div>

        </div>

        <!-- Pesquisa + Filtros -->
        <div class="search-filter-row">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" id="available-moves-search" class="search-input" placeholder="Buscar golpe por nome...">
            </div>
            <div class="filter-buttons">
                <button type="button" class="btn-filter active" data-filter="all"><i class="fa-solid fa-layer-group"></i> Todos</button>
                <button type="button" class="btn-filter" data-filter="lvl"><i class="fa-solid fa-circle-chevron-up"></i> Lvl</button>
                <button type="button" class="btn-filter" data-filter="tm"><i class="fa-solid fa-compact-disc"></i> TM</button>
            </div>
        </div>

        <!-- Lista de Golpes Disponíveis -->
        <!-- Tooltip flutuante -->
        {% include 'partials/tooltip.html.twig' %}

        <div class="available-moves-list" id="available-moves-list">
            {% for move in pokemon.moves %}

                {% set moveName = move.name is defined ? move.name : move %}
                {% set learnMethod = move.learn_method is defined ? move.learn_method : 'base' %}

                <div class="available-move-card"
                    data-move-name="{{ moveName }}"
                    data-learn-method="{{ learnMethod }}"
                    onclick="addMoveToFirstEmptySlot('{{ moveName }}')"
                    onmouseenter="showMoveTooltip(event, '{{ moveName }}')"
                    onmouseleave="hideMoveTooltip()"
                >
                    <span class="move-name">{{ moveName|replace({'-': ' '})|title }}</span>
                    <div class="move-badges">

                        {% if learnMethod == 'both' %}
                            <span class="learn-method-badge method-base">Lvl</span>
                            <span class="learn-method-badge method-tm">TM</span>
                        {% elseif learnMethod == 'TM' %}
                            <span class="learn-method-badge method-tm">TM</span>
                        {% else %}
                            <span class="learn-method-badge method-base">Lvl</span>
                        {% endif %}
                        
                        <span class="type-badge-sm type-badge-pd type-badge-loading"></span>
                    </div>
                </div>
                
            {% endfor %}
        </div>
    </div>

    <!-- Ações abaixo dos moves -->
    <div class="moveset-bottom-section card">
        <div class="form-actions">
            <a href="{{ path('app_pokemon_detail', { name: pokemon.name }) }}" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Salvar Moveset</button>
        </div>
    </div>

</form>


<script>
    const TYPE_IDS = {
        'normal': 1,
        'fighting': 2,
        'flying': 3,
        'poison': 4,
        'ground': 5,
        'rock': 6,
        'bug': 7,
        'ghost': 8,
        'steel': 9,
        'fire': 10,
        'water': 11,
        'grass': 12,
        'electric': 13,
        'psychic': 14,
        'ice': 15,
        'dragon': 16,
        'dark': 17,
        'fairy': 18,
        'stellar': 19,
        'unknown': 10001,
        'shadow': 10002
    };

    const cacheKeyPrefix = 'poke_move_type_';
    const MAX_MOVES = {{ maxMoves }};
    
    // Array dinâmico de slots baseado no limite do pokémon
    let selectedMoves = Array(MAX_MOVES).fill(null);
    let currentFilter = 'all';
    let searchQuery = '';

    // Formatar nome do golpe para exibição (substituir hifens por espaço, capitalizar palavras)
    function formatMoveName(name) {
        return name.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
    }

    // Obter URL do ícone do tipo
    function getTypeIconUrl(type) {
        const id = TYPE_IDS[type] || 1;
        return `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/types/generation-ix/scarlet-violet/small/${id}.png`;
    }

    // Obter dados do golpe (tipo, poder, categoria, descrição) com cache em localStorage
    async function getMoveData(moveName) {
        const cachedType        = localStorage.getItem(cacheKeyPrefix + moveName);
        const cachedPower       = localStorage.getItem(cacheKeyPrefix + moveName + '_power');
        const cachedCategory    = localStorage.getItem(cacheKeyPrefix + moveName + '_cat');
        const cachedDescription = localStorage.getItem(cacheKeyPrefix + moveName + '_desc');

        if (cachedType && cachedPower !== null && cachedCategory && cachedDescription) {
            return { type: cachedType, power: cachedPower, category: cachedCategory, description: cachedDescription };
        }
        try {
            const response = await fetch(`https://pokeapi.co/api/v2/move/${moveName}`);
            if (!response.ok) throw new Error('Falha na resposta da API');
            const data = await response.json();
            const type        = data.type.name;
            const power       = data.power ? String(data.power) : '—';
            const category    = data.damage_class ? data.damage_class.name : 'status';
            
            let description = '';
            if (data.flavor_text_entries && data.flavor_text_entries.length > 0) {
                const enEntry = data.flavor_text_entries.find(e => e.language.name === 'en');
                if (enEntry) {
                    description = enEntry.flavor_text.replace(/\n|\f|\r/g, ' ');
                }
            }
            if (!description && data.effect_entries && data.effect_entries.length > 0) {
                description = data.effect_entries[0].short_effect || data.effect_entries[0].effect;
            }

            localStorage.setItem(cacheKeyPrefix + moveName,           type);
            localStorage.setItem(cacheKeyPrefix + moveName + '_power', power);
            localStorage.setItem(cacheKeyPrefix + moveName + '_cat',   category);
            localStorage.setItem(cacheKeyPrefix + moveName + '_desc', description);
            return { type, power, category, description };
        } catch (e) {
            console.error('Erro ao buscar dados para ' + moveName, e);
            return { type: 'normal', power: '—', category: 'status', description: '' };
        }
    }

    // Compatível com loadAllMoveTypes: retorna apenas o tipo
    async function getMoveType(moveName) {
        const data = await getMoveData(moveName);
        return data.type;
    }

    // Atualizar o card de golpe disponível com o badge de tipo real
    function updateMoveCardType(card, type) {
        const badgeSpan = card.querySelector('.type-badge-sm');
        if (badgeSpan) {
            badgeSpan.className = `type-badge-sm type-badge-${type}`;
            const typeIconUrl = getTypeIconUrl(type);
            badgeSpan.innerHTML = `<img src="${typeIconUrl}" alt="${type}" class="move-type-icon"> ${type.charAt(0).toUpperCase() + type.slice(1)}`;
        }
    }

    // Tooltip: mostrar popup com dados do move
    window.showMoveTooltip = async function(event, moveName) {
        const title = formatMoveName(moveName);
        let loadingBody = `
            <div class="tooltip-row">
                <span class="tooltip-label">Tipo</span>
                <span class="tooltip-value"><span style="opacity:.5">...</span></span>
            </div>
            <div class="tooltip-row">
                <span class="tooltip-label">Poder</span>
                <span class="tooltip-value">...</span>
            </div>
            <div class="tooltip-row">
                <span class="tooltip-label">Categoria</span>
                <span class="tooltip-value">...</span>
            </div>
            <div class="tooltip-row tooltip-desc-row">
                <span class="tooltip-label">Descrição</span>
                <span class="tooltip-value">...</span>
            </div>
        `;
        showGenericTooltip(event, title, loadingBody);

        const moveData = await getMoveData(moveName);
        const typeIconUrl = getTypeIconUrl(moveData.type);
        const typeName = moveData.type.charAt(0).toUpperCase() + moveData.type.slice(1);

        const categoryMap = {
            'physical': { label: 'Físico',   icon: 'fa-hand-fist' },
            'special':  { label: 'Especial',  icon: 'fa-bolt' },
            'status':   { label: 'Status',    icon: 'fa-circle-dot' }
        };
        const cat = categoryMap[moveData.category] || categoryMap['status'];

        let finalBody = `
            <div class="tooltip-row">
                <span class="tooltip-label">Tipo</span>
                <span class="tooltip-value"><img src="${typeIconUrl}" class="move-type-icon" style="width:14px;height:14px"> ${typeName}</span>
            </div>
            <div class="tooltip-row">
                <span class="tooltip-label">Poder</span>
                <span class="tooltip-value">${moveData.power}</span>
            </div>
            <div class="tooltip-row">
                <span class="tooltip-label">Categoria</span>
                <span class="tooltip-value"><i class="fa-solid ${cat.icon}" style="font-size:0.75rem"></i> ${cat.label}</span>
            </div>
            <div class="tooltip-row tooltip-desc-row">
                <span class="tooltip-label">Descrição</span>
                <span class="tooltip-value">${moveData.description || 'Nenhuma descrição disponível.'}</span>
            </div>
        `;
        showGenericTooltip(event, title, finalBody);
    };

    window.hideMoveTooltip = function() {
        hideGenericTooltip();
    };

    // Carregar os tipos de todos os movimentos com throttling para evitar congestionamento
    async function loadAllMoveTypes() {
        const cards = document.querySelectorAll('.available-move-card');
        const chunkSize = 4; // busca em blocos menores para evitar gargalo
        for (let i = 0; i < cards.length; i += chunkSize) {
            const chunk = Array.from(cards).slice(i, i + chunkSize);
            let fetchPerformed = false;
            
            await Promise.all(chunk.map(async (card) => {
                const moveName = card.dataset.moveName;
                const hasCache = localStorage.getItem(cacheKeyPrefix + moveName) !== null;
                if (!hasCache) {
                    fetchPerformed = true;
                }
                const type = await getMoveType(moveName);
                updateMoveCardType(card, type);
            }));
            
            if (fetchPerformed) {
                // Pequena pausa se houver requisições de rede para não congestionar o navegador/CDP
                await new Promise(resolve => setTimeout(resolve, 300));
            }
        }
    }

    // Atualizar a interface dos slots escolhidos e os inputs ocultos
    function updateUI() {
        const slotsContainer = document.getElementById('selected-slots-list');
        slotsContainer.innerHTML = '';

        for (let i = 0; i < MAX_MOVES; i++) {
            const moveName = selectedMoves[i];
            const hiddenInput = document.getElementById('hidden-move-' + (i + 1));
            
            if (hiddenInput) {
                hiddenInput.value = moveName || '';
            }

            if (!moveName) {
                // Renderizar slot vazio
                const card = document.createElement('div');
                card.className = 'selected-slot-card empty';
                card.innerHTML = `
                    <span class="selected-slot-number">#${i + 1}</span>
                `;
                slotsContainer.appendChild(card);
            } else {
                // Renderizar slot ocupado
                const availableCard = document.querySelector(`.available-move-card[data-move-name="${moveName}"]`);
                const learnMethod = availableCard ? availableCard.dataset.learnMethod : 'base';
                const type = localStorage.getItem(cacheKeyPrefix + moveName) || 'normal';
                
                const card = document.createElement('div');
                card.className = `selected-slot-card border-type-${type}`;
                const learnLabel = learnMethod === 'TM' ? 'TM' : 'Lvl';
                const learnClass = learnMethod === 'TM' ? 'method-tm' : 'method-base';
                card.innerHTML = `
                    <span class="selected-slot-number">#${i + 1}</span>
                    <span class="selected-slot-name" title="${formatMoveName(moveName)}">${formatMoveName(moveName)}</span>
                    <div class="move-badges">
                        <span class="learn-method-badge ${learnClass}">${learnLabel}</span>
                        <span class="type-badge-sm type-badge-${type}">
                            <img src="${getTypeIconUrl(type)}" alt="${type}" class="move-type-icon">
                        </span>
                    </div>
                    <button type="button" class="remove-slot-btn" onclick="removeMoveFromSlot(${i})" title="Remover golpe">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                slotsContainer.appendChild(card);
            }
        }

        // Atualizar estado visual de selecionado nos cards da direita
        document.querySelectorAll('.available-move-card').forEach(card => {
            const moveName = card.dataset.moveName;
            if (selectedMoves.includes(moveName)) {
                card.classList.add('selected');
            } else {
                card.classList.remove('selected');
            }
        });

        updateCounter();
    }

    // Adicionar golpe ao primeiro slot vazio
    window.addMoveToFirstEmptySlot = function(moveName) {
        if (selectedMoves.includes(moveName)) {
            return;
        }
        const emptyIndex = selectedMoves.indexOf(null);
        if (emptyIndex === -1) {
            alert(`Você já selecionou o limite máximo de ${MAX_MOVES} movimentos.`);
            return;
        }
        selectedMoves[emptyIndex] = moveName;
        updateUI();
    };

    // Remover golpe de um slot e reorganizar a lista
    window.removeMoveFromSlot = function(index) {
        let activeMoves = selectedMoves.filter(m => m !== null);
        activeMoves.splice(index, 1);
        
        // Reconstrói o array com MAX_MOVES posições
        for (let i = 0; i < MAX_MOVES; i++) {
            selectedMoves[i] = activeMoves[i] || null;
        }
        updateUI();
    };

    // Aplicar filtros unificados (busca e método de aprendizado)
    function applyFilters() {
        const query = searchQuery.toLowerCase().replace(/[^a-z0-9]/g, '');
        document.querySelectorAll('.available-move-card').forEach(card => {
            const moveName   = card.dataset.moveName.toLowerCase().replace(/[^a-z0-9]/g, '');
            const displayName = card.querySelector('.move-name').textContent.toLowerCase().replace(/[^a-z0-9]/g, '');
            const learnMethod = card.dataset.learnMethod.toLowerCase(); // 'tm', 'base', ou 'both'
            
            const matchesSearch = moveName.includes(query) || displayName.includes(query);
            
            let matchesFilter = true;
            if (currentFilter === 'lvl') {
                // 'base' ou 'both' aparecem no filtro de level
                matchesFilter = (learnMethod === 'base' || learnMethod === 'both');
            } else if (currentFilter === 'tm') {
                // 'tm' ou 'both' aparecem no filtro de TM
                matchesFilter = (learnMethod === 'tm' || learnMethod === 'both');
            }
            
            if (matchesSearch && matchesFilter) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    // Filtro de pesquisa
    document.getElementById('available-moves-search').addEventListener('input', function(e) {
        searchQuery = e.target.value;
        applyFilters();
    });

    // Filtros por botões
    document.querySelectorAll('.btn-filter').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.btn-filter').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentFilter = this.dataset.filter;
            applyFilters();
        });
    });

    // Atualizar contador de slots
    function updateCounter() {
        const count = selectedMoves.filter(m => m !== null).length;
        const counter = document.getElementById('slots-counter');
        if (counter) counter.textContent = `(${count} / ${MAX_MOVES})`;
    }

    // Inicialização da página
    document.addEventListener('DOMContentLoaded', () => {
        updateUI();
        loadAllMoveTypes();
    });

    // Validação ao enviar o formulário
    document.querySelector('.moveset-form-wrapper').addEventListener('submit', function(e) {
        const activeMovesCount = selectedMoves.filter(m => m !== null).length;
        if (activeMovesCount < 4) {
            e.preventDefault();
            alert(`Por favor, selecione pelo menos 4 movimentos para salvar o moveset.`);
        }
    });
</script>
{% endblock %}
