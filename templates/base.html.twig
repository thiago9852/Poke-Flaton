<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}PokeFlaton | Os Melhores Movesets de Pokémon
			{% endblock %}
		</title>
		<link
		rel="icon" href="{{ asset('image/Pokeball.png') }}">

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Plus+Jakarta+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

		<!-- FontAwesome for Icons -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/style.css') }}">
			<link rel="stylesheet" href="{{ asset('css/base.css') }}">
		{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}

	</head>
	<body>

		<header class="app-header">
			<div class="container header-container">

				<a href="{{ path('app_home') }}" class="app-logo">
					<img src="{{ asset('image/PokeFlaton-pokeball.png') }}" alt="PokeFlaton" class="logo-img">
				</a>

				<!-- Botão Hambúrguer para Mobile -->
				<button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
					<i class="fa-solid fa-bars"></i>
				</button>

				<nav class="app-nav" id="appNav">
					<a href="{{ path('app_home') }}" class="nav-link">
						Início</a>
					<a href="{{ path('app_pokemon_index') }}" class="nav-link">
						Moveset</a>
					<a href="{{ path('app_game_daily') }}" class="nav-link">
						Pokémon do Dia</a>
					<a href="{{ path('app_trainer_ranking') }}" class="nav-link">
						Trainers</a>

					{% if app.user %}
						<div class="nav-user-dropdown" id="userDropdown">

							<button class="nav-link nav-user-btn" id="userDropdownBtn" aria-expanded="false" aria-haspopup="true">
								<img src="{{ avatar_url(app.user.avatar) }}" alt="Avatar" class="nav-user-avatar">
								<span>{{ app.user.username }}</span>
								<i class="fa-solid fa-chevron-down nav-dropdown-caret"></i>
							</button>

							<ul class="nav-dropdown-menu" role="menu">
								<li role="menuitem">
									<a href="{{ path('app_trainer_card') }}" class="nav-dropdown-item">
										Trainer Card</a>
								</li>
								<li class="nav-dropdown-divider" role="separator"></li>

								{% if is_granted('ROLE_ADMIN') %}
									<li role="menuitem">
										<a href="{{ path('app_admin') }}" class="nav-dropdown-item">
											Admin</a>
									</li>
									<li class="nav-dropdown-divider" role="separator"></li>
								{% endif %}

								<li role="menuitem">
									<a href="{{ path('app_logout') }}" class="nav-dropdown-item nav-dropdown-item--danger">
										<i class="fa-solid fa-right-from-bracket"></i>
										Sair</a>
								</li>
							</ul>

						</div>
					{% else %}
						<a href="{{ path('app_login') }}" class="nav-link">
							<i class="fa-solid fa-right-to-bracket"></i>
							Entrar</a>
					{% endif %}

					<span class="color: #fff;"><i class="fa-solid fa-bell"></i></span>
				</nav>
			</div>
		</header>

		<main class="app-main">
			<div class="container">

				{% for label, messages in app.flashes %}
					{% for message in messages %}
						<div class="alert alert-{{ label }}">
							{{ message }}
						</div>
					{% endfor %}
				{% endfor %}

				{% block body %}{% endblock %}

			</div>
		</main>

		<footer class="app-footer">
			<div class="footer-logo">
				<img src="{{ asset('image/PokeFlaton-logo.png') }}" alt="PokeFlaton">
			</div>
			<div class="container footer-container">
				<p>&copy;
					{{ 'now'|date('Y') }}
					PokeFlaton. Desenvolvido para entusiastas de Pokémon.</p>
				<p class="api-attribution">Dados fornecidos por
					<a href="https://pokeapi.co/" target="_blank">PokeAPI</a>
					e Sprites por
					<a href="https://github.com/PokeAPI/sprites" target="_blank">PokeAPI/sprites</a>.</p>
			</div>
		</footer>

		<script src="{{ asset('js/tabs.js') }}"></script>
		<script src="{{ asset('js/global-loading.js') }}"></script>

		<!-- Global Loading Overlay -->
		<div id="global-loader" class="global-loader-overlay">
			<div class="global-loader-content">
				<img src="{{ asset('image/Pokeball.png') }}" alt="Carregando..." class="global-loader-pokeball">
				<div class="global-loader-text">Carregando...</div>
			</div>
		</div>

	</body>
</html>
