<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}PokeFlaton - Os Melhores Movesets de Pokémon{% endblock %}</title>
        <link rel="icon" href="{{ asset('image/Pokeball.png') }}">
        
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Plus+Jakarta+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
        
        <!-- FontAwesome for Icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
            <link rel="stylesheet" href="{{ asset('css/base.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>

        <header class="app-header">
            <div class="container header-container">
                <a href="{{ path('app_home') }}" class="app-logo">
                    <img src="{{ asset('image/PokeFlaton-pokeball.png') }}" alt="PokeFlaton" class="logo-img">
                </a>
                <nav class="app-nav">
                    <a href="{{ path('app_home') }}" class="nav-link"> Início</a>
                    <a href="{{ path('app_pokemon_index') }}" class="nav-link"> Pokémons</a>
                </nav>
            </div>
        </header>

        <main class="app-main">
            <div class="container">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>

        <footer class="app-footer">
            <div class="footer-logo">
                <img src="{{ asset('image/PokeFlaton-logo.png') }}" alt="PokeFlaton">
            </div>
            <div class="container footer-container">
                <p>&copy; {{ 'now'|date('Y') }} PokeFlaton. Desenvolvido para entusiastas de Pokémon.</p>
                <p class="api-attribution">Dados fornecidos por <a href="https://pokeapi.co/" target="_blank">PokeAPI</a> e Sprites por <a href="https://github.com/PokeAPI/sprites" target="_blank">PokeAPI/sprites</a>.</p>
            </div>
        </footer>
        
    </body>
</html>
