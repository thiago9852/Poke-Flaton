<!DOCTYPE html>
<html lang="{{ app.request.locale|replace({'_': '-'}) }}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}PokeFlaton | Os Melhores Movesets de Pokémon
			{% endblock %}
		</title>
		<link
		rel="icon" href="{{ asset('image/Pokeball.png') }}">

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Plus+Jakarta+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

		<!-- FontAwesome & Bootstrap Icons -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/style.css') }}">
			<link rel="stylesheet" href="{{ asset('css/base.css') }}">
		{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}

	</head>
	<body>

		<header class="app-header">
			<div class="container header-container">

				<a href="{{ path('app_home') }}" class="app-logo">
					<img src="{{ asset('image/PokeFlaton-pokeball.png') }}" alt="PokeFlaton" class="logo-img">
				</a>

				<!-- Botão Hambúrguer para Mobile -->
				<button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
					<i class="fa-solid fa-bars"></i>
				</button>

				<nav class="app-nav" id="appNav">
					<a href="{{ path('app_home') }}" class="nav-link">
						{{ 'Início'|trans }}</a>
					<a href="{{ path('app_pokemon_index') }}" class="nav-link">
						{{ 'Moveset'|trans }}</a>
					<a href="{{ path('app_move_search') }}" class="nav-link">
						{{ 'Buscar Golpes'|trans }}</a>
					<a href="{{ path('app_tier_list') }}" class="nav-link">
						{{ 'Tier List'|trans }}</a>
					<!-- <a href="{{ path('app_map') }}" class="nav-link">
						{{ 'Mini Mapa'|trans }}</a> -->

					{% if app.user %}
						<div class="nav-user-dropdown" id="userDropdown">

							<button class="nav-link nav-user-btn" id="userDropdownBtn" aria-expanded="false" aria-haspopup="true">
								<span style="display: flex; align-items: center; gap: 8px;">
									<img src="{{ avatar_url(app.user.avatar) }}" alt="Avatar" class="nav-user-avatar">
									<span>{{ app.user.username }}</span>
								</span>
								<i class="fa-solid fa-chevron-down nav-dropdown-caret"></i>
							</button>

							<ul class="nav-dropdown-menu" role="menu">
								<li role="menuitem">
									<a href="{{ path('app_trainer_card') }}" class="nav-dropdown-item">
										{{ 'Trainer Card'|trans }}</a>
								</li>
								<li class="nav-dropdown-divider" role="separator"></li>

								{% if is_granted('ROLE_ADMIN') %}
									<li role="menuitem">
										<a href="{{ path('app_admin') }}" class="nav-dropdown-item">
											{{ 'Admin'|trans }}</a>
									</li>
									<li class="nav-dropdown-divider" role="separator"></li>
								{% endif %}

								<li role="menuitem">
									<a href="{{ path('app_logout') }}" class="nav-dropdown-item nav-dropdown-item--danger">
										<i class="fa-solid fa-right-from-bracket"></i>
										{{ 'Sair'|trans }}</a>
								</li>
							</ul>

						</div>
					{% else %}
						<a href="{{ path('app_login') }}" class="nav-link">
							<i class="fa-solid fa-right-to-bracket"></i>
							{{ 'Entrar'|trans }}</a>
					{% endif %}

					<!-- <a href="#" class="nav-link nav-notification-btn" title="{{ 'Notificações'|trans }}">
						<i class="fa-solid fa-bell"></i>
					</a> -->

					<div class="nav-lang-dropdown" id="langDropdown">
						<button class="nav-link nav-lang-btn" id="langDropdownBtn" aria-expanded="false" aria-haspopup="true">
							<span style="display: flex; align-items: center; gap: 8px;">
								<i class="fa-solid fa-earth-americas"></i>
							</span>
							<i class="fa-solid fa-chevron-down nav-dropdown-caret"></i>
						</button>
						<ul class="nav-dropdown-menu" role="menu" style="min-width: 130px;">
							<li role="menuitem">
								<a href="{{ path('app_change_locale', { locale: 'pt_BR' }) }}" class="nav-dropdown-item {% if app.request.locale != 'en' %}active-lang{% endif %}" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
									<span>Português</span>
									{% if app.request.locale != 'en' %}
										<i class="fa-solid fa-check" style="font-size: 0.8rem; color: var(--color-primary);"></i>
									{% endif %}
								</a>
							</li>
							<li role="menuitem">
								<a href="{{ path('app_change_locale', { locale: 'en' }) }}" class="nav-dropdown-item {% if app.request.locale == 'en' %}active-lang{% endif %}" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
									<span>English</span>
									{% if app.request.locale == 'en' %}
										<i class="fa-solid fa-check" style="font-size: 0.8rem; color: var(--color-primary);"></i>
									{% endif %}
								</a>
							</li>
						</ul>
					</div>
				</nav>
			</div>
		</header>

		<main class="app-main">
			<div class="container">

				{% for label, messages in app.flashes %}
					{% for message in messages %}
						<div class="alert alert-{{ label }}">
							{{ message|trans }}
						</div>
					{% endfor %}
				{% endfor %}

				{% block body %}{% endblock %}

			</div>
		</main>

		<footer class="app-footer">
			<div class="footer-logo">
				<img src="{{ asset('image/PokeFlaton-logo.png') }}" alt="PokeFlaton">
			</div>
			<div class="container footer-container">
				<p>&copy;
					{{ 'now'|date('Y') }}
					{{ 'PokeFlaton. Pokémon e todos os nomes relacionados são marcas registradas da Nintendo, Game Freak e The Pokémon Company.'|trans }}</p>
				<p class="api-attribution">
					{{ 'Dados fornecidos por'|trans }}
					<a href="https://pokeapi.co/" target="_blank">PokeAPI</a>
					{{ 'e Sprites por'|trans }}
					<a href="https://github.com/PokeAPI/sprites" target="_blank">PokeAPI/sprites</a>.</p>
			</div>
		</footer>

		<script src="{{ asset('js/tabs.js') }}"></script>
		<script src="{{ asset('js/global-loading.js') }}"></script>

		<!-- Global Loading Overlay -->
		<div id="global-loader" class="global-loader-overlay">
			<div class="global-loader-content">
				<img src="{{ asset('image/Pokeball.png') }}" alt="{{ 'Carregando...'|trans }}" class="global-loader-pokeball">
				<div class="global-loader-text">{{ 'Carregando...'|trans }}</div>
			</div>
		</div>

		<!-- Botão Flutuante Pokémon do Dia -->
		<a href="{{ path('app_game_daily') }}" class="floating-game-btn" title="{{ 'Jogar Pokémon do Dia'|trans }}" data-turbo="false">
			<img src="{{ asset('image/Pokeball.png') }}" class="floating-game-pokeball" alt="Pokeball">
			<span class="floating-game-text">{{ 'Pokémon do Dia'|trans }}</span>
		</a>

	</body>
</html>
