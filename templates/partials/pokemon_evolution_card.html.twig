<div class="card pokemon-evolution-card">
    <h2 class="card-title"><i class="fa-solid fa-dna"></i> Linha Evolutiva</h2>
    
    {% if evolutionChain is empty %}
        <p class="no-drops-text" style="color: var(--text-secondary); font-style: italic; font-size: 0.95rem; margin: 10px 0;">Este Pokémon não possui evolução cadastrada.</p>
    {% else %}
        <div class="evolution-chain-container">
            {% for evo in evolutionChain %}

                <div class="evolution-node-wrapper">
                    
                    <a href="{{ path('app_pokemon_detail', { name: evo.name }) }}" 
                        class="evolution-node {% if evo.name == pokemon.name %}active{% endif %}" 
                    >
                        <img src="{{ evo.sprite }}" alt="{{ evo.name|capitalize }}" class="evolution-sprite">

                        <div class="evolution-details">
                            <span class="evolution-id">#{{ "%04d"|format(evo.id) }}</span>
                            <span class="evolution-name" style="display: block; font-family: 'Outfit', sans-serif;">{{ evo.name|capitalize }}</span>

                            <div class="evolution-types">
                                {% if evo.types is defined %}
                                    {% for type in evo.types %}
                                        {% include 'partials/type_badge.html.twig' with {'type': type, 'typeDetails': typeDetails} %}
                                    {% endfor %}
                                {% endif %}
                            </div>

                        </div>
                    </a>
                    
                    {% if not loop.last %}
                        <div class="evolution-arrow">
                            <span class="evolution-method">
                                {{ evo.evolution_method|default('Nível/Stone') }}
                            </span>
                            <i class="fa-solid fa-chevron-right"></i>
                        </div>
                    {% endif %}
                    
                </div>
            {% endfor %}

        </div>
    {% endif %}
    
</div>
