<div class="move-detail-item">
    {% if moveIndex is defined and moveIndex %}
        <span class="move-index-watermark">#{{ moveIndex }}</span>
    {% endif %}

    <div class="move-detail-header">
        <span class="move-name-text">
            {{ moveName|replace({'-': ' '})|title }}
        </span>
        
        <div class="move-header-badges">
            {% set moveMeta = pokemon.moves[moveName] ?? null %}
            {% set learnMethod = (moveMeta is iterable and moveMeta.learn_method is defined) ? moveMeta.learn_method : 'base' %}
            
            <span class="badge {{ learnMethod == 'TM' ? 'bg-info' : 'bg-secondary' }}">
                {{ learnMethod == 'TM' ? 'TM' : 'Lvl'|trans }}
            </span>
            
            {% if md %}
                <span class="type-badge-sm type-badge-{{ md.type }}" 
                    style="display: inline-flex; align-items: center; padding-right: 6px; font-size: 0.8em; border-radius: 4px;"
                >
                    <img src="{{ md.type_icon }}" class="move-type-icon-md" style="margin-right: 4px;"> {{ md.type|capitalize|trans }}
                </span>
            {% endif %}
        </div>
    </div>

    {% if md %}
        <div class="move-detail-stats">
            <span>
                {% if md.category == 'physical' %}
                    <i class="fa-solid fa-hand-fist"></i> {{ 'Físico'|trans }}
                {% elseif md.category == 'special' %}
                    <i class="fa-solid fa-sparkles"></i> {{ 'Especial'|trans }}
                {% else %}
                    <i class="fa-solid fa-shield"></i> {{ 'Status'|trans }}
                {% endif %}
            </span>
            
            {% if md.power %}
                <span><i class="fa-solid fa-fire"></i> {{ md.power }}</span>
            {% endif %}
            
            {% if md.accuracy %}
                <span><i class="fa-solid fa-bullseye"></i> {{ md.accuracy }}%</span>
            {% endif %}
        </div>
        
        <p class="move-desc" title="{{ md.description }}">{{ md.description }}</p>
    {% endif %}
</div>
