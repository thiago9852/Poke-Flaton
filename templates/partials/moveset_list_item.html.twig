<div class="card moveset-list-item">

	<div class="d-flex justify-content-between align-items-start mb-2">
		<div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">

			<div style="font-size: 0.9em; color: #aaa; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; width: 100%;">

				<span style="display: flex; align-items: center; gap: 5px; color: #fff; font-weight: bold;">
					{% if m2.author and m2.author != 'Anônimo' %}
						<a href="{{ path('app_trainer_profile', { username: m2.author }) }}" style="display: flex; align-items: center; gap: 5px; color: var(--color-secondary);">
							<i class="fa-solid fa-circle-user" style="font-size: 20px; color: var(--color-primary);"></i>
							{{ m2.author }}
						</a>
					{% else %}
						<img src="{{ asset('image/Pokeball.png') }}" style="width: 20px; height: 20px; object-fit: contain;" alt="Anônimo">
						{{ m2.author|default('Anônimo') }}
					{% endif %}
				</span>

				<span class="badge bg-primary" style="display: inline-flex; align-items: center; gap: 4px;">
					{% if m2.type == 'padrao' %}
						<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/poke-ball.png" style="width: 14px;">
						PADRÃO
					{% elseif m2.type == 'pvp' %}
						<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/choice-scarf.png" style="width: 14px;">
						PvP
					{% elseif m2.type == 'dg' %}
						<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/dream-world/escape-rope.png" style="width: 14px;">
						DG
					{% else %}
						{{ m2.type|capitalize }}
					{% endif %}
				</span>

				{% if m2.isDefault %}
					<span class="badge bg-success" style="background-color: #10b981; color: #fff; display: inline-flex; align-items: center; gap: 4px; font-weight: bold; height: 22px;">
						<i class="fa-solid fa-star"></i> Padrão Oficial
					</span>
				{% endif %}

				<span>&bull;
					{{ m2.createdAt|date('d/m/Y') }}</span>

				<div style="margin-left: auto; display: inline-flex; gap: 8px; align-items: center;">
					{% if is_granted('ROLE_ADMIN') %}
						{% if m2.isDefault %}
							<form method="post" action="{{ path('app_admin_moveset_remove_default', {'id': m2.id}) }}" style="display: inline; margin: 0;">
								<button type="submit" class="btn btn-sm btn-outline-danger mt-1" title="Remover Padrão" style="padding: 6px 10px; border-radius: 20px; font-size: 0.85rem; height: 32px; border: 1px solid #ef4444; color: #ef4444; background: transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; width: 32px;">
									<i class="fa-solid fa-star-half-stroke"></i>
								</button>
							</form>
						{% else %}
							<form method="post" action="{{ path('app_admin_moveset_default', {'id': m2.id}) }}" style="display: inline; margin: 0;">
								<button type="submit" class="btn btn-sm btn-outline-success mt-1" title="Tornar Padrão Oficial" style="padding: 6px 10px; border-radius: 20px; font-size: 0.85rem; height: 32px; border: 1px solid #10b981; color: #10b981; background: transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; width: 32px;">
									<i class="fa-solid fa-star"></i>
								</button>
							</form>
						{% endif %}
					{% endif %}

					<button class="btn btn-sm btn-outline-secondary share-btn mt-1" onclick="openShareModal('{{ m2.id }}')" title="Compartilhar Moveset" style="padding: 6px 10px; border-radius: 20px; font-size: 0.85rem; height: 32px; background-color: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); color: var(--text-secondary); cursor: pointer; display: inline-flex; align-items: center; justify-content: center;">
						<i class="fa-solid fa-share-nodes"></i>
					</button>

					<button class="upvote-btn btn btn-sm btn-outline-primary mt-1" data-id="{{ m2.id }}" title="Curtir" style="margin: 0; padding: 6px 12px; border-radius: 20px; font-size: 0.85rem; height: 32px; display: inline-flex; align-items: center; gap: 6px;">
						Gostei
						<i class="fa-regular fa-thumbs-up"></i>
						<span class="vote-count">{{ m2.votes }}</span>
					</button>
				</div>

			</div>

			<div style="display: flex; align-items: center; gap: 10px; margin-left: auto; margin-bottom: 20px;">
				{% if m2.nature and naturesMap is defined and naturesMap[m2.nature] is defined %}
					<div style="display: inline-flex; align-items: center; background: rgba(0,0,0,0.2); padding: 2px 8px; border-radius: 10px; font-size: 0.9em; height: 28px;">
						{% include 'partials/tooltip_trigger.html.twig' with {
                            'title': 'Nature: ' ~ naturesMap[m2.nature].name|capitalize,
                            'content': '+' ~ naturesMap[m2.nature].increased|capitalize ~ ' / -' ~ naturesMap[m2.nature].decreased|capitalize,
                            'label': naturesMap[m2.nature].name|capitalize
                        } %}
					</div>
				{% endif %}

				{% if m2.heldItem %}
					<div class="item-moveset-list outhers-moves-list" style="margin-left: 0; margin-bottom: 0; height: 28px;">
						<img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/{{ m2.heldItem }}.png" style="width: 24px; height: 24px;" alt="{{ m2.heldItem }}">

						{% include 'partials/tooltip_trigger.html.twig' with {
                            'title': 'Item: ' ~ m2.heldItem|replace({'-': ' '})|title,
                            'content': itemDetails[m2.heldItem].description|default('Item recomendado.'),
                            'label': m2.heldItem|replace({'-': ' '})|title
                        } %}
					</div>
				{% endif %}
			</div>

		</div>
	</div>

	<!-- Mini Moves Badge -->
	<div class="moves-mini-list mt-2" style="display: flex; flex-wrap: wrap; gap: 5px;">
		{% for mv in m2.moves %}
			{% if mv %}
				{% include 'partials/move_badge.html.twig' with {
                    'moveName': mv,
                    'moveDetails': moveDetails,
                    'learnMethod': (pokemon.moves[mv] is defined and pokemon.moves[mv] is iterable and pokemon.moves[mv].learn_method is defined) ? pokemon.moves[mv].learn_method : null
                } %}
			{% endif %}
		{% endfor %}
	</div>

</div>
