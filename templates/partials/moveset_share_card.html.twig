<!-- Share Card for Moveset {{ m.id }} -->
<div id="share-card-{{ m.id }}" class="share-card-canvas-container">
    <!-- Accent Background Glow matching primary type -->
    <div class="share-card-glow type-glow-{{ pokemon.types|first }}"></div>

    <!-- Header Area -->
    <div class="share-card-header">
        <div class="share-logo-section">
            <img src="{{ asset('image/PokeFlaton-pokeball.png') }}" class="share-logo-img" alt="Pokeball">
            <span class="share-logo-text">Poke<span style="color: var(--color-primary);">Flaton</span></span>
        </div>
        <div class="share-category-section">
            <span class="share-category-badge">
                {% if m.type == 'padrao' %}
                    PADRÃO
                {% else %}
                    {{ m.type|upper }}
                {% endif %}
            </span>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="share-card-body">
        <!-- Column 1: Pokemon Art & Info -->
        <div class="share-column share-column-pokemon" style="justify-content: space-between;">
            <!-- Build Details (Item, Nature, Ability) stacked on top -->
            <div style="display: flex; flex-direction: column; gap: 6px; width: 100%; margin-bottom: 10px;">
                <div style="display: flex; gap: 6px; width: 100%;">
                    {% if m.heldItem %}
                        <div class="share-build-box" style="flex: 1.1; padding: 6px 8px; gap: 6px; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; display: flex; align-items: center; min-width: 0;">
                            <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/{{ m.heldItem }}.png" style="width: 22px; height: 22px; object-fit: contain; flex-shrink: 0;" alt="{{ m.heldItem }}">
                            <div style="display: flex; flex-direction: column; line-height: 1.1; min-width: 0; flex-grow: 1;">
                                <span style="font-size: 0.55rem; color: #8b8b9a; font-weight: bold; text-transform: uppercase; letter-spacing: 0.2px;">Item</span>
                                <span style="font-size: 0.75rem; color: #fff; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="{{ m.heldItem|replace({'-': ' '})|title }}">{{ m.heldItem|replace({'-': ' '})|title }}</span>
                            </div>
                        </div>
                    {% endif %}

                    <div class="share-build-box" style="flex: 0.9; padding: 6px 8px; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; display: flex; align-items: center; min-width: 0;">
                        <div style="display: flex; flex-direction: column; line-height: 1.1; min-width: 0; flex-grow: 1;">
                            <span style="font-size: 0.55rem; color: #8b8b9a; font-weight: bold; text-transform: uppercase; letter-spacing: 0.2px;">Nature</span>
                            <span style="font-size: 0.75rem; color: #fff; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ m.nature|capitalize }}</span>
                        </div>
                    </div>
                </div>

                <div class="share-build-box" style="padding: 6px 8px; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                    <div style="display: flex; flex-direction: column; line-height: 1.1; min-width: 0; flex-grow: 1;">
                        <span style="font-size: 0.55rem; color: #8b8b9a; font-weight: bold; text-transform: uppercase; letter-spacing: 0.2px;">Habilidade</span>
                        <span style="font-size: 0.75rem; color: #fff; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ m.ability|replace({'-': ' '})|title }}</span>
                    </div>
                </div>
            </div>

            <!-- Pokémon Image, Name, and Types -->
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; width: 100%;">
                <div class="share-pokemon-sprite-container" style="height: 110px; width: 110px; margin-bottom: 6px;">
                    <img id="share-pokemon-artwork-{{ m.id }}" 
                         src="{{ pokemon.sprite_official }}" 
                         class="share-pokemon-image" 
                         alt="{{ pokemon.name|capitalize }}">
                </div>
                <h2 class="share-pokemon-name" style="font-size: 1.4rem;">{{ pokemon.name|capitalize }}</h2>
                <div class="share-pokemon-id" style="margin: 0 0 6px;">Nº {{ "%04d"|format(pokemon.species_id) }}</div>
                <div class="share-pokemon-types">
                    {% for type in pokemon.types %}
                        <span class="type-badge type-badge-{{ type }} no-tooltip" style="font-size: 0.65rem; padding: 2px 8px; border-radius: 4px;">{{ type|capitalize }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Column 2: Build Details & Moves -->
        <div class="share-column share-column-build" style="justify-content: center; gap: 8px;">
            <div class="share-moves-section" style="width: 100%;">
                <span class="share-section-title">Golpes Recomendados</span>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 8px;">
                    {% for moveName in m.moves %}
                        {% if moveName %}
                            {% set md = moveDetails[moveName] ?? null %}
                            <div class="share-move-item" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 6px; padding: 4px 8px; display: flex; justify-content: space-between; align-items: center; box-sizing: border-box; height: 36px; min-width: 0;">
                                <div style="display: flex; align-items: center; gap: 6px; min-width: 0; flex-grow: 1;">
                                    <!-- Category Icon -->
                                    <span style="display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; border-radius: 3px; background: rgba(0,0,0,0.3); font-size: 0.65rem; flex-shrink: 0;">
                                        {% if md.category is defined %}
                                            {% if md.category == 'physical' %}
                                                <i class="fa-solid fa-hand-fist" title="Físico" style="color: #ef4444; font-size: 0.6rem;"></i>
                                            {% elseif md.category == 'special' %}
                                                <i class="fa-solid fa-bolt" title="Especial" style="color: #3b82f6; font-size: 0.6rem;"></i>
                                            {% else %}
                                                <i class="fa-solid fa-circle-dot" title="Status" style="color: #10b981; font-size: 0.6rem;"></i>
                                            {% endif %}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </span>
                                    
                                    <span style="font-weight: 800; font-size: 0.8rem; color: #ffffff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="{{ moveName|replace({'-': ' '})|title }}">{{ moveName|replace({'-': ' '})|title }}</span>
                                </div>
                                <span class="type-badge-sm type-badge-{{ md.type|default('normal') }} no-tooltip" style="font-size: 0.55rem; padding: 1px 4px; border-radius: 2px; font-weight: bold; text-transform: uppercase; color: white; flex-shrink: 0; margin-left: 4px;">{{ md.type|default('normal')|slice(0,3)|upper }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Column 3: QR Code Redirect -->
        <div class="share-column share-column-qr">
            <div class="share-qr-container">
                <div id="share-qr-{{ m.id }}" class="share-qr-code-placeholder">
                    <!-- QR Code Canvas dynamically injected via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Area -->
    <div class="share-card-footer">
        <div class="share-footer-left">
            <i class="fa-solid fa-circle-user"></i>
            <span>Criado por <strong>{{ m.author|default('Anônimo') }}</strong> em {{ m.createdAt|date('d/m/Y') }}</span>
        </div>
        <div class="share-footer-right">
            <span>PokeFlaton &copy; {{ 'now'|date('Y') }}</span>
        </div>
    </div>
</div>
