<div class="moveset-card card moveset-highlight" style="padding: 20px;">
    <!-- Ações (topo) -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">
        <div style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 0.9em; color: var(--text-secondary); display: flex; align-items: center; gap: 6px;">
                {% if m.author and m.author != 'Anônimo' %}
                    <a href="{{ path('app_trainer_profile', { username: m.author }) }}" style="display: flex; align-items: center; gap: 5px; color: var(--color-secondary); font-weight: bold;">
                        <i class="fa-solid fa-circle-user" style="font-size: 16px; color: var(--color-primary);"></i>
                        {{ m.author }}
                    </a>
                {% else %}
                    <span style="display: flex; align-items: center; gap: 5px; color: #fff; font-weight: bold;">
                        <img src="{{ asset('image/Pokeball.png') }}" style="width: 16px; height: 16px; object-fit: contain;" alt="Anônimo">
                        {{ m.author|default('Anônimo') }}
                    </span>
                {% endif %}
                <span style="color: var(--text-muted); font-weight: normal;">&bull; {{ m.createdAt|date('d/m/Y') }}</span>
            </span>
        </div>
        <button class="btn btn-sm btn-outline-secondary share-btn" onclick="openShareModal('{{ m.id }}')" title="Compartilhar Moveset" style="padding: 6px 12px; font-size: 0.85rem; height: 32px; border-radius: 20px; background-color: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); color: var(--text-secondary); cursor: pointer;">
            <i class="fa-solid fa-share-nodes"></i> Compartilhar
        </button>
    </div>

    <div class="moveset-grid" style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px;">
        
        <!-- Moves Recomendados -->
        <div class="moveset-section-moves">
            <h4 class="moveset-title">Golpes recomendados</h4>
            
            <div class="moves-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                {% for moveName in m.moves %}
                    {% if moveName %}
                        {% set md = moveDetails[moveName] ?? null %}
                        {% include 'partials/move_detail_item.html.twig' with {'moveName': moveName, 'md': md, 'pokemon': pokemon} %}
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <!-- Infos (Item, Nature, Ability) -->
        <div class="build-summary-section" style="display: flex; flex-direction: column; gap: 15px;">
            
            {% if m.heldItem %}
                <div class="build-sub-section">
                    <h4 class="moveset-title">Item</h4>
                    
                    <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                        <div style="background: rgba(0,0,0,0.2); padding: 5px; border-radius: 8px; display: flex; justify-content: center; align-items: center;">
                            <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/{{ m.heldItem }}.png" style="width: 30px; height: 30px;" alt="{{ m.heldItem }}">
                        </div>
                        
                        {% include 'partials/tooltip_trigger.html.twig' with {
                            'title': 'Item: ' ~ m.heldItem|replace({'-': ' '})|title,
                            'content': itemDetails[m.heldItem].description|default('Item recomendado.'),
                            'label': m.heldItem|replace({'-': ' '})|title
                        } %}
                    </div>
                </div>
            {% endif %}

            <div class="build-sub-section">
                <h4 class="moveset-title">Nature</h4>
                
                <div style="margin-bottom: 15px;">
                    <span style="font-weight: bold; color: #fff;">{{ m.nature|capitalize }}</span>
                    <p style="font-size: 0.85em; color: #aaa; margin: 0;">
                        {% if naturesMap[m.nature] is defined %}
                            + {{ naturesMap[m.nature].increased|replace({'-': ' '})|title }} / - {{ naturesMap[m.nature].decreased|replace({'-': ' '})|title }}
                        {% else %}
                            Nature ideal.
                        {% endif %}
                    </p>
                </div>
            </div>

            {% if m.ability %}
                <div class="build-sub-section">
                    <h4 class="moveset-title">Ability</h4>
                    
                    <div style="margin-bottom: 15px;">
                        {% include 'partials/tooltip_trigger.html.twig' with {
                            'title': 'Ability: ' ~ m.ability|replace({'-': ' '})|title,
                            'content': abilityDetails[m.ability].description|default('Habilidade recomendada.'),
                            'label': m.ability|replace({'-': ' '})|title
                        } %}
                    </div>
                </div>
            {% endif %}
            
        </div>
        
    </div>
</div>
