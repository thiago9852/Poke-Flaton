{% set typeName = type|capitalize %}
{% set rel = (typeDetails is defined and typeDetails[type] is defined) ? typeDetails[type].damage_relations|default(null) : null %}

<span class="type-badge type-badge-{{ type }}" style="cursor: pointer;"
      data-tooltip-title="{{ 'Tipo'|trans }} {{ typeName|trans }}"
      onmouseenter="showTemplateTooltip(event)"
      onmouseleave="hideGenericTooltip()">
    {{ typeName|trans }}

    <template class="js-tooltip-template">
        {% if rel %}
            {% if rel.double_damage_to|length > 0 %}
                <div style="margin-bottom: 5px;">
                    <strong style="color: #4CAF50;">{{ 'Forte Contra (2x):'|trans }}</strong><br>
                    {% for d in rel.double_damage_to %}
                        <span class="type-badge-sm type-badge-pd type-badge-{{ d.name }}" style="margin-bottom: 5px;">
                            {{ d.name|capitalize|trans }}
                        </span>
                    {% endfor %}
                </div>
            {% endif %}

            {% if rel.half_damage_to|length > 0 %}
                <div style="margin-bottom: 5px;">
                    <strong style="color: #ff4d4d;">{{ 'Fraco Contra (0.5x):'|trans }}</strong><br>
                    {% for d in rel.half_damage_to %}
                        <span class="type-badge-sm type-badge-pd type-badge-{{ d.name }}" style="margin-bottom: 5px;">
                            {{ d.name|capitalize|trans }}
                        </span>
                    {% endfor %}
                </div>
            {% endif %}

            {% if rel.no_damage_to|length > 0 %}
                <div style="margin-bottom: 5px;">
                    <strong style="color: #ccc;">{{ 'Sem Efeito (0x):'|trans }}</strong><br>
                    {% for d in rel.no_damage_to %}
                        <span class="type-badge-sm type-badge-pd type-badge-{{ d.name }}" style="margin-bottom: 5px;">
                            {{ d.name|capitalize|trans }}
                        </span>
                    {% endfor %}
                </div>
            {% endif %}
        {% else %}
            {{ 'Sem detalhes de tipo disponíveis.'|trans }}
        {% endif %}
    </template>
</span>
