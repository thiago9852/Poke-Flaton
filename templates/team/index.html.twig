{% extends 'base.html.twig' %}

{% block title %}{{ 'Montar Time'|trans }} | PokeFlaton{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
	<link rel="stylesheet" href="{{ asset('css/team-builder.css') }}">
{% endblock %}

{% block body %}
	<div class="team-builder-container">
		<!-- Header da Página -->
		<div class="team-builder-header">
			<div class="team-header-title">
				<h1>
					<i class="fa-solid fa-users-line" style="color: var(--color-primary);"></i>
					{{ 'Montar Time (Team Builder)'|trans }}
				</h1>
			</div>

			<div class="team-header-actions">
				<button type="button" class="btn btn-outline-danger btn-sm" id="btn-clear-team">
					<i class="fa-solid fa-trash-can"></i> {{ 'Limpar Time'|trans }}
				</button>
				<button type="button" class="btn btn-outline-secondary btn-sm" id="btn-open-io-modal">
					<i class="fa-solid fa-file-code"></i> {{ 'Importar / Exportar JSON'|trans }}
				</button>
				<button type="button" class="btn btn-outline-success btn-sm" id="btn-export-team-image">
					<i class="fa-solid fa-image"></i> {{ 'Exportar Imagem'|trans }}
				</button>
				<button type="button" class="btn btn-primary btn-sm" id="btn-copy-team-text">
					<i class="fa-solid fa-copy"></i> {{ 'Copiar Resumo do Time'|trans }}
				</button>
			</div>
		</div>

		<!-- Lista dos 6 Slots de Pokémon -->
		<div class="team-slots-list">
			{% for slotIdx in 1..6 %}
				<div class="team-slot-card" id="team-slot-card-{{ slotIdx }}" data-slot-id="{{ slotIdx }}">
					<!-- Limpar Slot -->
					<button type="button" class="team-clear-slot-btn" title="{{ 'Remover Pokémon deste slot'|trans }}" onclick="clearSlot({{ slotIdx }})">
						<i class="fa-solid fa-xmark"></i>
					</button>

					<!-- Coluna Esquerda: Tag/Função, Sprite e Seleção -->
					<div class="team-slot-left">
						<div class="team-slot-number">#{{ slotIdx }}</div>

						<!-- Tag / Função Personalizada -->
						<div class="team-left-tag-container" style="width: 100%; margin-bottom: 8px;">
							<label class="team-build-label" style="font-size: 0.7rem; margin-bottom: 4px; justify-content: center;">
								<i class="fa-solid fa-tags" style="color: #a855f7;"></i>
								{{ 'Tag / Função'|trans }}
							</label>
							<select id="role-preset-slot-{{ slotIdx }}" class="team-build-input team-role-tag-select" style="font-size: 0.75rem; padding: 4px 6px; margin-bottom: 4px; width: 100%; text-align: center;">
								<option value="">-- {{ 'Função'|trans }} --</option>
								{% for role in rolesList %}
									<option value="{{ role }}">{{ role }}</option>
								{% endfor %}
							</select>
							<input type="text" id="role-custom-slot-{{ slotIdx }}" class="team-build-input" style="font-size: 0.75rem; padding: 4px 8px; width: 100%; text-align: center;" placeholder="{{ 'ex: Suporte Clima...'|trans }}">
						</div>

						<div class="team-pokemon-sprite-container">
							<img id="sprite-slot-{{ slotIdx }}" src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/25.png" alt="Pikachu" class="team-pokemon-sprite" style="opacity: 0.3;">
						</div>

						<div class="team-slot-search-wrapper">
							<input type="text"
							       id="search-slot-{{ slotIdx }}"
							       class="team-slot-search-input"
							       placeholder="{{ 'Buscar Pokémon...'|trans }}"
							       autocomplete="off"
							       data-slot="{{ slotIdx }}">
							<div id="autocomplete-slot-{{ slotIdx }}" class="autocomplete-dropdown" style="display: none; position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 100;"></div>
						</div>
					</div>

					<!-- Coluna Principal: Top Build Bar & Golpes Inline 1-10 -->
					<div class="team-slot-main">
						<!-- Top Bar (Item, Nature, Ability) -->
						<div class="team-slot-build-bar">
							<!-- Item -->
							<div class="team-build-field">
								<label class="team-build-label">
									{{ 'Item'|trans }}
								</label>
								<input type="text" id="item-slot-{{ slotIdx }}" class="team-build-input" placeholder="ex: leftovers" autocomplete="off">
							</div>

							<!-- Nature -->
							<div class="team-build-field">
								<label class="team-build-label">
									{{ 'Nature'|trans }}
								</label>
								<select id="nature-slot-{{ slotIdx }}" class="team-build-input">
									<option value="">-- {{ 'Selecione'|trans }} --</option>
									{% for nKey, nInfo in naturesMap %}
										<option value="{{ nKey }}">{{ nKey|capitalize }} (+{{ nInfo.increased }} / -{{ nInfo.decreased }})</option>
									{% endfor %}
								</select>
							</div>

							<!-- Habilidade -->
							<div class="team-build-field">
								<label class="team-build-label">
									{{ 'Habilidade'|trans }}
								</label>
								<input type="text" id="ability-slot-{{ slotIdx }}" class="team-build-input" placeholder="ex: blaze" autocomplete="off">
							</div>
						</div>

						<!-- Seção de Golpes Inline (1 a 10) -->
						<div class="team-slot-moves-section">
							<div class="team-slot-moves-header" style="display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap;">
								<span style="display: flex; align-items: center; gap: 6px;">
									{{ 'Golpes Sugeridos / Selecionados (1 a 10)'|trans }}
								</span>

								<!-- Carregar Moveset Dropdown -->
								<div style="display: flex; align-items: center; gap: 6px;">
									<label for="moveset-preset-slot-{{ slotIdx }}" style="font-size: 0.75rem; font-weight: 700; color: #c4b5fd; white-space: nowrap; margin: 0;">
										{{ 'Carregar Moveset:'|trans }}
									</label>
									<select id="moveset-preset-slot-{{ slotIdx }}" class="team-build-input" style="font-size: 0.8rem; padding: 3px 8px; font-weight: 600; background: rgba(0,0,0,0.4); border-color: rgba(139, 92, 246, 0.4); min-width: 180px; max-width: 250px;">
										<option value="base">-- {{ 'Golpes Base'|trans }} --</option>
									</select>
								</div>
							</div>

							<div class="team-slot-moves-grid">
								{% for moveIdx in 1..10 %}
									<div class="team-move-inline-card" id="move-card-{{ slotIdx }}-{{ moveIdx }}">
										<span class="team-move-inline-badge">#{{ moveIdx }}</span>
										<div class="team-move-inline-header">
											<span id="move-type-badge-{{ slotIdx }}-{{ moveIdx }}" class="type-badge" style="display: none; padding: 2px 6px; font-size: 0.7rem;"></span>
											<input type="text"
											       id="move-input-{{ slotIdx }}-{{ moveIdx }}"
											       class="team-move-name-input"
											       placeholder="Golpe {{ moveIdx }}"
											       autocomplete="off"
											       data-slot="{{ slotIdx }}"
											       data-move-idx="{{ moveIdx }}">
										</div>
										<div id="move-stats-{{ slotIdx }}-{{ moveIdx }}" class="team-move-stats-row">
											<span class="text-muted" style="font-size: 0.7rem;">—</span>
										</div>
									</div>
								{% endfor %}
							</div>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>

	<!-- Modal Importar / Exportar JSON -->
	<div id="team-io-modal" class="team-modal-backdrop" style="display: none;">
		<div class="team-modal-card">
			<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
				<h3 style="margin: 0; color: #fff;">{{ 'Importar / Exportar Time em JSON'|trans }}</h3>
				<button type="button" class="btn btn-sm btn-outline-secondary" onclick="closeIoModal()">
					<i class="fa-solid fa-xmark"></i>
				</button>
			</div>

			<textarea id="team-json-area" rows="12" class="form-input" style="width: 100%; box-sizing: border-box; font-family: monospace; font-size: 0.85rem; padding: 12px; background: rgba(0,0,0,0.3); color: #fff; border: 1px solid var(--border-color); border-radius: 8px; resize: vertical;" placeholder='[\n  {\n    "name": "charizard",\n    "nature": "jolly",\n    "heldItem": "leftovers",\n    "ability": "blaze",\n    "role": "Dano Bruto",\n    "moves": ["flamethrower", "solar-beam", "roost", "dragon-claw"]\n  }\n]'></textarea>

			<div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 15px;">
				<button type="button" class="btn btn-secondary btn-sm" id="btn-copy-modal-json">
					<i class="fa-solid fa-copy"></i> {{ 'Copiar JSON'|trans }}
				</button>
				<button type="button" class="btn btn-primary btn-sm" id="btn-import-modal-json">
					<i class="fa-solid fa-file-import"></i> {{ 'Importar JSON'|trans }}
				</button>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
	<script src="{{ asset('js/team-builder.js') }}?v=1.0.1"></script>
{% endblock %}
