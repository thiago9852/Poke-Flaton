{% extends 'base.html.twig' %}

{% block title %}Trainer Master | PokeFlaton
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/trainer-card.css') }}">
	<link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
	<div
		class="admin-wrapper">
		<!-- Flashes -->
		{% for label, messages in app.flashes %}
			{% for message in messages %}
				<div class="alert alert-{{ label == 'error' ? 'error' : 'success' }}">
					<i class="fa-solid {{ label == 'error' ? 'fa-circle-exclamation' : 'fa-circle-check' }}"></i>
					{{ message }}
				</div>
			{% endfor %}
		{% endfor %}

		<!-- Stats -->
		{% set totalEnabled = enabledMedals|length %}
		{% set totalMedals = 0 %}
		{% for cat, medals in medalDefs %}
			{% set totalMedals = totalMedals + medals|length %}
		{% endfor %}
		{% set totalMedals = totalMedals + allVivillonPatterns|length %}

		<div class="admin-tabs" style="margin-bottom: 30px;">
			<a href="{{ path('app_admin') }}" class="admin-tab-btn active">
				<i class="fa-solid fa-sliders"></i>
				Personalização & Medalhas
			</a>
			<a href="{{ path('app_admin_pokemon') }}" class="admin-tab-btn">
				<i class="fa-solid fa-gamepad"></i>
				Dados de Pokémon
			</a>
		</div>

		<div class="admin-stats-row">
			<div class="admin-stat-card">
				<div class="admin-stat-num users">{{ totalUsers }}</div>
				<div class="admin-stat-label">Treinadores</div>
			</div>
			<div class="admin-stat-card">
				<div class="admin-stat-num enabled" id="stat-enabled">{{ totalEnabled + enabledVivillonPats|length }}</div>
				<div class="admin-stat-label">Medalhas Ativas</div>
			</div>
			<div class="admin-stat-card">
				<div class="admin-stat-num disabled" id="stat-disabled">{{ totalMedals - (totalEnabled + enabledVivillonPats|length) }}</div>
				<div class="admin-stat-label">Medalhas Bloqueadas</div>
			</div>
			<div class="admin-stat-card">
				<div class="admin-stat-num total">{{ totalMedals }}</div>
				<div class="admin-stat-label">Total de Medalhas</div>
			</div>
		</div>

		<!-- Ações -->
		<div class="bulk-actions">
			<button class="btn-bulk-enable" onclick="bulkAction('enable_all')">
				<i class="fa-solid fa-check-double"></i>
				Ativar Todas
			</button>
			<button class="btn-bulk-disable" onclick="bulkAction('disable_all')">
				<i class="fa-solid fa-ban"></i>
				Bloquear Todas
			</button>
		</div>

		<!-- Medalhas Categorias -->
		{% for category, medals in medalDefs %}
			{% set catId = 'medal-cat-' ~ loop.index %}
			<div class="admin-category">
				<div class="admin-category-header" onclick="toggleCategorySection('{{ catId }}-content', '{{ catId }}-chevron')">
					<h2>{{ category }}</h2>
					<span class="admin-hero-badge">{{ medals|length }}
						medalhas</span>
					<i class="fa-solid fa-chevron-down admin-category-chevron" id="{{ catId }}-chevron"></i>
				</div>
				<div id="{{ catId }}-content" class="admin-category-content">
					<div class="admin-medals-grid">
						{% for medal in medals %}
							{% set isOn = medal.key in enabledMedals %}
							<div class="admin-medal-card {{ isOn ? 'is-enabled' : 'is-disabled' }}" id="admin-card-{{ medal.key }}">
								<img src="{{ badgeBaseUrl }}{{ medal.badge }}" alt="{{ medal.title }}" class="admin-medal-img" loading="lazy">
								<div class="admin-medal-info">
									<div class="admin-medal-name">{{ medal.title }}</div>
									<div class="admin-medal-key">{{ medal.key }}</div>
								</div>
								<label class="toggle-switch" title="{{ medal.title }}">
									<input type="checkbox" {{ isOn ? 'checked' : '' }} onchange="toggleMedal('{{ medal.key }}', this.checked, 'medal')" id="toggle-{{ medal.key }}">
									<span class="toggle-slider"></span>
								</label>
							</div>
						{% endfor %}
					</div>
				</div>
			</div>
		{% endfor %}

		<!-- Padrões de Vivillon -->
		<div class="admin-category">
			<div class="admin-category-header" onclick="toggleCategorySection('vivillon-content', 'vivillon-chevron')">
				<h2>Vivillon's Patterns</h2>
				<span class="admin-hero-badge">20 padrões</span>
				<i class="fa-solid fa-chevron-down admin-category-chevron" id="vivillon-chevron"></i>
			</div>
			<div id="vivillon-content" class="admin-category-content">
				<div class="vivillon-admin-grid">
					{% set vivillonSprites = {
					'meadow':      'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/meadow.png',
					'archipelago': 'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/archipelago.png',
					'continental': 'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/continental.png',
					'elegant':     'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/elegant.png',
					'garden':      'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/garden.png',
					'high-plains': 'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/high_plains.png',
					'icy-snow':    'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/icy_snow.png',
					'jungle':      'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/jungle.png',
					'marine':      'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/marine.png',
					'modern':      'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/modern.png',
					'monsoon':     'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/monsoon.png',
					'ocean':       'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/ocean.png',
					'polar':       'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/polar.png',
					'river':       'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/river.png',
					'sandstorm':   'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/sandstorm.png',
					'savanna':     'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/savanna.png',
					'sun':         'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/sun.png',
					'tundra':      'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/tundra.png',
					'fancy':       'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/fancy.png',
					'poke-ball':   'https://raw.githubusercontent.com/PokeMiners/pogo_assets/master/Images/Badges/Vivillon/pokeball.png'
				} %}
					{% for pattern in allVivillonPatterns %}
						{% set isOn = pattern in enabledVivillonPats %}
						<div class="vivillon-admin-card {{ isOn ? 'is-enabled' : 'is-disabled' }}" id="admin-vivillon-{{ pattern }}" onclick="toggleMedal('{{ pattern }}', document.getElementById('vtoggle-{{ pattern }}').checked ? false : true, 'vivillon')">
							<img src="{{ vivillonSprites[pattern] }}" alt="{{ pattern }}" class="vivillon-admin-sprite" loading="lazy">
							<div class="vivillon-admin-label">{{ pattern|replace({'-': ' '})|title }}</div>
							<label class="toggle-switch" onclick="event.stopPropagation()">
								<input type="checkbox" id="vtoggle-{{ pattern }}" {{ isOn ? 'checked' : '' }} onchange="toggleMedal('{{ pattern }}', this.checked, 'vivillon')">
								<span class="toggle-slider"></span>
							</label>
						</div>
					{% endfor %}
				</div>
			</div>
		</div>



		<!-- Gerenciamento de Títulos de Treinador -->
		<div class="admin-category spaced" id="trainer-titles-section">
			<div class="admin-category-header" onclick="toggleCategorySection('titles-content', 'titles-chevron')">
				<h2>Títulos de Trainers</h2>
				<span class="admin-hero-badge">{{ titles|length }}
					títulos</span>
				<i class="fa-solid fa-chevron-down admin-category-chevron" id="titles-chevron"></i>
			</div>

			<div id="titles-content" class="admin-category-content">
				<!-- Criar novo título Form -->

				<div class="admin-card-container padded">
					<h3 class="admin-section-title mb-15">Criar Novo Título</h3>

					{{ form_start(titleForm) }}
					<div class="title-form-grid">
						<div>
							<label class="title-form-label">Nome do Título</label>
							{{ form_widget(titleForm.name, {'attr': {'class': 'form-input'}}) }}
						</div>
						<div>
							<label class="title-form-label">Ribbon (Faixa)</label>
							{{ form_widget(titleForm.ribbon, {'attr': {'class': 'form-input'}}) }}
						</div>
						<div>
							<label class="title-form-label">Descrição do Requisito</label>
							{{ form_widget(titleForm.requirement, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Medalha Cientista no nível Bronze'}}) }}
						</div>
						<div>
							<label class="title-form-label">Medalha Requerida</label>
							{{ form_widget(titleForm.reqMedal, {'attr': {'class': 'form-input'}}) }}
						</div>
						<div>
							<label class="title-form-label">Nível da Medalha</label>
							{{ form_widget(titleForm.reqTier, {'attr': {'class': 'form-input'}}) }}
						</div>
						<div>
							<label class="title-form-label">Qtd Medalhas Ouro</label>
							{{ form_widget(titleForm.reqGoldCount, {'attr': {'class': 'form-input', 'placeholder': 'Vazio se não aplicar'}}) }}
						</div>
					</div>
					<div class="title-form-footer">
						<label class="title-form-checkbox-label">
							{{ form_widget(titleForm.isDefault) }}
							Disponível por padrão (Sem requisitos)?
						</label>
						<button type="submit" class="btn btn-primary">
							<i class="fa-solid fa-plus"></i>
							Salvar Título
						</button>
					</div>
					{{ form_end(titleForm) }}
				</div>

				<!-- Listagem de títulos -->
				<div class="admin-card-container overflow-hidden">
					<table class="admin-table">
						<thead>
							<tr>
								<th style="width: 80px;">Ribbon</th>
								<th>Título</th>
								<th>Requisito Exibido</th>
								<th>Requisitos (Medalhas / Ranking)</th>
								<th class="text-center" style="width: 120px;">Padrão?</th>
								<th class="text-right" style="width: 180px;">Ações</th>
							</tr>
						</thead>
						<tbody>

							{% for title in titles %}
								{% set ribbonUrl = title.ribbon|slice(0, 4) == 'http' or title.ribbon|slice(0, 5) == 'https' ? title.ribbon : 'https://raw.githubusercontent.com/msikma/pokesprite/master/misc/ribbon/gen8/' ~ title.ribbon %}

								<tr>
									<form method="post" action="{{ path('app_admin_title_update', {'id': title.id}) }}">
										<td>
											<img src="{{ ribbonUrl }}" alt="Ribbon" class="title-ribbon-img">
										</td>
										<td>
											<strong style="display: block;">{{ title.name }}</strong>
											<span class="text-muted" style="font-size: 0.75rem;">{{ title.ribbon }}</span>
										</td>
										<td>
											<input type="text" name="requirement" value="{{ title.requirement }}" class="form-input" style="width: 100%; font-size: 0.85rem;" placeholder="Ex: Medalha de Hoenn de Ouro">
										</td>
										<td>
											<div style="display: flex; gap: 6px;">
												<select name="reqMedal" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 2; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="">Nenhuma Medalha</option>
													{% for cat, medals in medalDefs %}
														<optgroup label="{{ cat }}">
															{% for m in medals %}
																<option value="{{ m.key }}" {% if title.reqMedal == m.key %}selected{% endif %}>{{ m.title }}</option>
															{% endfor %}
														</optgroup>
													{% endfor %}
												</select>
												<select name="reqTier" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="bronze" {% if title.reqTier == 'bronze' %}selected{% endif %}>Bronze</option>
													<option value="silver" {% if title.reqTier == 'silver' %}selected{% endif %}>Prata</option>
													<option value="gold" {% if title.reqTier == 'gold' or title.reqTier is empty %}selected{% endif %}>Ouro</option>
												</select>
												<input type="number" name="reqGoldCount" value="{{ title.reqGoldCount }}" class="form-input" style="width: 60px; font-size: 0.8rem; padding: 4px;" placeholder="Ouro" title="Quantidade de medalhas de ouro requeridas">
											</div>
											<div style="display: flex; gap: 6px; margin-top: 6px; align-items: center;">
												<span style="font-size: 0.75rem; color: var(--text-secondary); white-space: nowrap;">Ou Ranking:</span>
												<select name="reqRankType" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="">Nenhum Ranking</option>
													<option value="likes" {% if title.reqRankType == 'likes' %}selected{% endif %}>Curtidas (Top 3)</option>
													<option value="medals" {% if title.reqRankType == 'medals' %}selected{% endif %}>Medalhas (Top 3)</option>
												</select>
												<select name="reqRankPos" class="form-input" style="font-size: 0.8rem; padding: 4px; width: 80px; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="3" {% if title.reqRankPos == 3 or title.reqRankPos is empty %}selected{% endif %}>Top 3</option>
													<option value="2" {% if title.reqRankPos == 2 %}selected{% endif %}>Top 2</option>
													<option value="1" {% if title.reqRankPos == 1 %}selected{% endif %}>Top 1</option>
												</select>
											</div>
										</td>
										<td class="text-center">
											<input type="checkbox" name="isDefault" value="1" {% if title.isDefault %}checked{% endif %} class="admin-checkbox">
										</td>
										<td class="text-right">
											<div style="display: flex; gap: 6px; justify-content: flex-end;">
												<button type="submit" class="btn btn-primary btn-sm">
													<i class="fa-solid fa-floppy-disk"></i>
													Salvar
												</button>
												{% if not title.isDefault %}
													<button type="submit" formAction="{{ path('app_admin_title_delete', {'id': title.id}) }}" class="btn-admin-reject btn-sm" onclick="return confirm('Deseja realmente excluir este título?')" style="padding: 6px 12px; font-size: 0.8rem;">
														<i class="fa-solid fa-trash-can"></i>
														Excluir
													</button>
												{% endif %}
											</div>
										</td>
									</form>
								</tr>
							{% endfor %}

						</tbody>
					</table>

				</div>
			</div>

		</div>

		<!-- Gerenciamento de Modelos de Trainer Card -->
		<div class="admin-category spaced" id="card-templates-section">
			<div class="admin-category-header" onclick="toggleCategorySection('templates-content', 'templates-chevron')">
				<h2>Planos de Fundo do Card</h2>
				<span class="admin-hero-badge">{{ templates|length }}
					modelos</span>
				<i class="fa-solid fa-chevron-down admin-category-chevron" id="templates-chevron"></i>
			</div>

			<div id="templates-content" class="admin-category-content">
				<div class="admin-card-container padded admin-flex-between" style="margin-bottom: 20px;">
					<div>
						<h3 class="admin-section-title" style="margin: 0;">Sincronização e Regras</h3>
						<p class="text-muted" style="font-size: 0.85rem; margin-top: 4px; color: var(--text-muted);">Sincronize novos planos de fundo da API do GitHub sem alterar as regras customizadas, ou limpe e restaure os padrões.</p>
					</div>
					<div style="display: flex; gap: 10px; align-items: center;">
						<form method="post" action="{{ path('app_admin_templates_sync') }}">
							<button type="submit" class="btn btn-primary">
								<i class="fa-solid fa-rotate"></i>
								Sincronizar
							</button>
						</form>
						<form method="post" action="{{ path('app_admin_templates_reset') }}" onsubmit="return confirm('ATENÇÃO: Isso irá apagar todas as customizações de requisitos feitas nos planos de fundo. Deseja prosseguir?')">
							<button type="submit" class="btn-admin-reject" style="padding: 10px 16px; border: none; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: bold; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
								<i class="fa-solid fa-trash-arrow-up"></i>
								Restaurar
							</button>
						</form>
					</div>
				</div>

				<div class="admin-card-container overflow-hidden">
					<table class="admin-table" id="admin-templates-table">
						<thead>
							<tr>
								<th style="width: 100px;">Miniatura</th>
								<th>Nome</th>
								<th>Requisito Exibido</th>
								<th>Requisitos (Medalhas / Ranking)</th>
								<th class="text-center" style="width: 120px;">Padrão?</th>
								<th class="text-right" style="width: 180px;">Ações</th>
							</tr>
						</thead>
						<tbody>
							{% for template in templates %}
								{% set imageUrl = template.image|slice(0, 4) == 'http' ? template.image : 'https://raw.githubusercontent.com/thiago9852/pokemon-sprite/main/sprites/src/templates/' ~ template.image %}
								
								<tr>
									<form method="post" action="{{ path('app_admin_template_update', {'id': template.id}) }}">
										<td>
											<img src="{{ imageUrl }}" alt="{{ template.name }}" style="width: 80px; height: 45px; object-fit: cover; border-radius: var(--radius-xs); border: 1px solid var(--border-color);">
										</td>
										<td>
											<strong style="display: block;">{{ template.name }}</strong>
											<span class="text-muted" style="font-size: 0.75rem;">{{ template.image }}</span>
										</td>
										<td>
											<input type="text" name="requirement" value="{{ template.requirement }}" class="form-input" style="width: 100%; font-size: 0.85rem;" placeholder="Ex: Medalha de Hoenn de Ouro">
										</td>
										<td>
											<div style="display: flex; gap: 6px;">
												<select name="reqMedal" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 2; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="">Nenhuma Medalha</option>
													{% for cat, medals in medalDefs %}
														<optgroup label="{{ cat }}">
															{% for m in medals %}
																<option value="{{ m.key }}" {% if template.reqMedal == m.key %}selected{% endif %}>{{ m.title }}</option>
															{% endfor %}
														</optgroup>
													{% endfor %}
												</select>
												<select name="reqTier" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="bronze" {% if template.reqTier == 'bronze' %}selected{% endif %}>Bronze</option>
													<option value="silver" {% if template.reqTier == 'silver' %}selected{% endif %}>Prata</option>
													<option value="gold" {% if template.reqTier == 'gold' or template.reqTier is empty %}selected{% endif %}>Ouro</option>
												</select>
												<input type="number" name="reqGoldCount" value="{{ template.reqGoldCount }}" class="form-input" style="width: 60px; font-size: 0.8rem; padding: 4px;" placeholder="Ouro" title="Quantidade de medalhas de ouro requeridas">
											</div>
											<div style="display: flex; gap: 6px; margin-top: 6px; align-items: center;">
												<span style="font-size: 0.75rem; color: var(--text-secondary); white-space: nowrap;">Ou Ranking:</span>
												<select name="reqRankType" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="">Nenhum Ranking</option>
													<option value="likes" {% if template.reqRankType == 'likes' %}selected{% endif %}>Curtidas (Top 3)</option>
													<option value="medals" {% if template.reqRankType == 'medals' %}selected{% endif %}>Medalhas (Top 3)</option>
												</select>
												<select name="reqRankPos" class="form-input" style="font-size: 0.8rem; padding: 4px; width: 80px; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="3" {% if template.reqRankPos == 3 or template.reqRankPos is empty %}selected{% endif %}>Top 3</option>
													<option value="2" {% if template.reqRankPos == 2 %}selected{% endif %}>Top 2</option>
													<option value="1" {% if template.reqRankPos == 1 %}selected{% endif %}>Top 1</option>
												</select>
											</div>
										</td>
										<td class="text-center">
											<input type="checkbox" name="isDefault" value="1" {% if template.isDefault %}checked{% endif %} class="admin-checkbox">
										</td>
										<td class="text-right">
											<div style="display: flex; gap: 6px; justify-content: flex-end;">
												<button type="submit" class="btn btn-primary btn-sm">
													<i class="fa-solid fa-floppy-disk"></i>
													Salvar
												</button>
												{% if not template.isDefault %}
													<button type="submit" formAction="{{ path('app_admin_card_template_delete', {'id': template.id}) }}" class="btn-admin-reject btn-sm" onclick="return confirm('Deseja realmente excluir este plano de fundo?')" style="padding: 6px 12px; font-size: 0.8rem;">
														<i class="fa-solid fa-trash-can"></i>
														Excluir
													</button>
												{% endif %}
											</div>
										</td>
									</form>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>

		</div>

		<!-- Gerenciamento de Avatares -->
		<div class="admin-category spaced" id="avatars-section">
			<div class="admin-category-header" onclick="toggleCategorySection('avatars-content', 'avatars-chevron')">
				<h2>Gerenciamento de Avatares</h2>
				<span class="admin-hero-badge">{{ avatars|length }} avatares</span>
				<i class="fa-solid fa-chevron-down admin-category-chevron" id="avatars-chevron"></i>
			</div>

			<div id="avatars-content" class="admin-category-content">
				<div class="admin-card-container padded admin-flex-between" style="margin-bottom: 20px;">
					<div>
						<h3 class="admin-section-title" style="margin: 0;">Sincronização e Regras</h3>
						<p class="text-muted" style="font-size: 0.85rem; margin-top: 4px; color: var(--text-muted);">Sincronize novos avatares sem alterar as regras customizadas, ou limpe o banco e restaure os padrões de fábrica.</p>
					</div>
					<div style="display: flex; gap: 10px; align-items: center;">
						<form method="post" action="{{ path('app_admin_avatars_sync') }}">
							<button type="submit" class="btn btn-primary">
								<i class="fa-solid fa-rotate"></i>
								Sincronizar
							</button>
						</form>
						<form method="post" action="{{ path('app_admin_avatars_reset') }}" onsubmit="return confirm('ATENÇÃO: Isso irá apagar todas as customizações de requisitos feitas e restaurará os avatares aos seus padrões corretos. Deseja prosseguir?')">
							<button type="submit" class="btn-admin-reject" style="padding: 10px 16px; border: none; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: bold; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
								<i class="fa-solid fa-trash-arrow-up"></i>
								Restaurar
							</button>
						</form>
					</div>
				</div>

				<div class="admin-card-container padded mb-15">
					<div style="display: flex; gap: 15px; align-items: center;">
						<div style="flex: 1;">
							<input type="text" id="avatar-admin-search" onkeyup="filterAdminAvatars()" placeholder="Buscar por nome do avatar..." class="form-input" style="width: 100%;">
						</div>
						<div style="width: 200px;">
							<select id="avatar-admin-type-filter" onchange="filterAdminAvatars()" class="form-input" style="width: 100%;">
								<option value="all">Todos os Tipos</option>
								<option value="trainer">Treinadores</option>
								<option value="pkm">Pokémon</option>
							</select>
						</div>
					</div>
				</div>

				<div class="admin-card-container overflow-hidden">
					<table class="admin-table" id="admin-avatars-table">
						<thead>
							<tr>
								<th style="width: 60px;">Avatar</th>
								<th>Nome & Tipo</th>
								<th>Requisito Exibido</th>
								<th>Medalha Requerida / Nível / Qtd Ouro</th>
								<th class="text-center" style="width: 120px;">Padrão?</th>
								<th class="text-right" style="width: 100px;">Ações</th>
							</tr>
						</thead>
						<tbody>
							{% for avatar in avatars %}
								{% set shortName = avatar.filename|replace({'trainer:': '', 'pkm:': ''}) %}
								{% set displayName = shortName|replace({'.png': '', '-': ' ', '_': ' '})|title %}
								
								<tr class="avatar-admin-row" data-name="{{ displayName|lower }}" data-type="{{ avatar.type }}">
									<form method="post" action="{{ path('app_admin_avatar_update', {'id': avatar.id}) }}">
										<td>
											<img src="{{ avatar_url(avatar.filename) }}" alt="{{ displayName }}" style="width: 40px; height: 40px; object-fit: contain;">
										</td>
										<td>
											<strong style="display: block;">{{ displayName }}</strong>
											<span class="text-muted" style="font-size: 0.75rem; text-transform: uppercase;">{{ avatar.type }}</span>
										</td>
										<td>
											<input type="text" name="requirement" value="{{ avatar.requirement }}" class="form-input" style="width: 100%; font-size: 0.85rem;" placeholder="Ex: Medalha de Hoenn de Ouro">
										</td>
										<td>
											<div style="display: flex; gap: 6px;">
												<select name="reqMedal" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 2; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="">Nenhuma Medalha</option>
													{% for cat, medals in medalDefs %}
														<optgroup label="{{ cat }}">
															{% for m in medals %}
																<option value="{{ m.key }}" {% if avatar.reqMedal == m.key %}selected{% endif %}>{{ m.title }}</option>
															{% endfor %}
														</optgroup>
													{% endfor %}
												</select>
												<select name="reqTier" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="bronze" {% if avatar.reqTier == 'bronze' %}selected{% endif %}>Bronze</option>
													<option value="silver" {% if avatar.reqTier == 'silver' %}selected{% endif %}>Prata</option>
													<option value="gold" {% if avatar.reqTier == 'gold' or avatar.reqTier is empty %}selected{% endif %}>Ouro</option>
												</select>
												<input type="number" name="reqGoldCount" value="{{ avatar.reqGoldCount }}" class="form-input" style="width: 60px; font-size: 0.8rem; padding: 4px;" placeholder="Ouro" title="Quantidade de medalhas de ouro requeridas">
											</div>
											<div style="display: flex; gap: 6px; margin-top: 6px; align-items: center;">
												<span style="font-size: 0.75rem; color: var(--text-secondary); white-space: nowrap;">Ou Ranking:</span>
												<select name="reqRankType" class="form-input" style="font-size: 0.8rem; padding: 4px; flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="">Nenhum Ranking</option>
													<option value="likes" {% if avatar.reqRankType == 'likes' %}selected{% endif %}>Curtidas (Top 3)</option>
													<option value="medals" {% if avatar.reqRankType == 'medals' %}selected{% endif %}>Medalhas (Top 3)</option>
												</select>
												<select name="reqRankPos" class="form-input" style="font-size: 0.8rem; padding: 4px; width: 80px; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--border-color);">
													<option value="3" {% if avatar.reqRankPos == 3 or avatar.reqRankPos is empty %}selected{% endif %}>Top 3</option>
													<option value="2" {% if avatar.reqRankPos == 2 %}selected{% endif %}>Top 2</option>
													<option value="1" {% if avatar.reqRankPos == 1 %}selected{% endif %}>Top 1</option>
												</select>
											</div>
										</td>
										<td class="text-center">
											<input type="checkbox" name="isDefault" value="1" {% if avatar.isDefault %}checked{% endif %} class="admin-checkbox">
										</td>
										<td class="text-right">
											<button type="submit" class="btn btn-primary btn-sm">
												<i class="fa-solid fa-floppy-disk"></i>
												Salvar
											</button>
										</td>
									</form>
					</tr>
					{% endfor %}
					</tbody>
				</table>
				</div>
			</div>
		</div>

	<!-- Toast -->
	<div class="admin-toast" id="admin-toast">
		<i class="fa-solid fa-check-circle"></i>
		<span id="toast-msg">Salvo!</span>
	</div>
{% endblock %}

{% block javascripts %}

	{% set totalMedals = 0 %}
	{% for cat, medals in medalDefs %}
		{% set totalMedals = totalMedals + medals|length %}
	{% endfor %}
	{% set totalMedals = totalMedals + allVivillonPatterns|length %}

	<script>
		let enabledCount = parseInt('{{ (enabledMedals|length + enabledVivillonPats|length) }}');
		const totalCount = parseInt('{{ totalMedals }}');

		function showToast(msg, isError = false) {
			const toast = document.getElementById('admin-toast');
			const msgEl = document.getElementById('toast-msg');
			msgEl.textContent = msg;
			toast.style.borderColor = isError ? 'rgba(239,68,68,0.4)' : 'rgba(16,185,129,0.4)';
			toast.style.color = isError ? '#fca5a5' : '#a7f3d0';
			toast.classList.add('show');
			clearTimeout(toast._hideTimeout);
			toast._hideTimeout = setTimeout(() => toast.classList.remove('show'), 2800);
		}

		function updateStats(delta) {
			enabledCount = Math.max(0, Math.min(totalCount, enabledCount + delta));
			document.getElementById('stat-enabled').textContent = enabledCount;
			document.getElementById('stat-disabled').textContent = totalCount - enabledCount;
		}

		function toggleMedal(medalKey, enabled, type) {
			const cardId = type === 'vivillon' ? `admin-vivillon-${medalKey}` : `admin-card-${medalKey}`;
			const toggleId = type === 'vivillon' ? `vtoggle-${medalKey}` : `toggle-${medalKey}`;
			const card = document.getElementById(cardId);
			const toggle = document.getElementById(toggleId);

			if (card) {
				card.classList.toggle('is-enabled', enabled);
				card.classList.toggle('is-disabled', !enabled);
			}

			if (toggle) {
				toggle.checked = enabled;
			}

			updateStats(enabled ? 1 : -1);

			const formData = new FormData();
			formData.append('medal', medalKey);
			formData.append('enabled', enabled ? 'true' : 'false');
			formData.append('type', type);

			fetch('/admin/medal/toggle', {
				method: 'POST',
				body: formData
			}).then(r => r.json()).then(data => {
				if (data.success) {
					showToast(`"${medalKey}" ${enabled ? 'ativada ✓' : 'bloqueada ✗'}`);
				} else {
					showToast('Erro ao salvar!', true);
				}
			}).catch(() => showToast('Erro de conexão!', true));
		}

		function bulkAction(action) {
			if (!confirm(action === 'enable_all' ? 'Ativar TODAS as medalhas?' : 'Bloquear TODAS as medalhas?')) {
				return;
			}

			const formData = new FormData();
			formData.append('action', action);

			fetch('/admin/medals/bulk', {
				method: 'POST',
				body: formData
			}).then(r => r.json()).then(data => {
				if (data.success) {
					showToast(action === 'enable_all' ? 'Todas as medalhas ativadas!' : 'Todas as medalhas bloqueadas!');
					setTimeout(() => window.location.reload(), 1200);
				}
			});
		}



		// Filtro local de avatares no Admin
		window.filterAdminAvatars = function () {
			const query = document.getElementById('avatar-admin-search').value.toLowerCase().trim();
			const type = document.getElementById('avatar-admin-type-filter').value;
			
			document.querySelectorAll('.avatar-admin-row').forEach(row => {
				const name = row.dataset.name;
				const rowType = row.dataset.type;
				
				const matchesQuery = name.includes(query);
				const matchesType = (type === 'all' || rowType === type);
				
				if (matchesQuery && matchesType) {
					row.style.display = '';
				} else {
					row.style.display = 'none';
				}
			});
		};

	</script>


{% endblock %}
