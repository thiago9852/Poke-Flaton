{% extends 'base.html.twig' %}

{% block title %}Cadastrar-se | PokeFlaton
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/trainer-card.css') }}">
{% endblock %}

{% block body %}
	<div class="auth-container">
		<div class="auth-card card register-card">
			<div class="detail-glow register-glow"></div>
			<div class="auth-header">
				<img src="{{ asset('image/PokeFlaton-pokeball.png') }}" alt="PokeFlaton" class="auth-logo">
				<h1 class="auth-title">Crie sua Conta</h1>
				<p class="auth-subtitle">Registre-se para desbloquear seu Trainer Card e começar a jornada!</p>
			</div>

			{% if errors is not empty %}
				<div class="alert alert-error">
					<ul class="errors-list">
						{% for error in errors %}
							<li>
								<i class="fa-solid fa-circle-exclamation"></i>
								{{ error }}</li>
						{% endfor %}
					</ul>
				</div>
			{% endif %}

			{{ form_start(form, {'attr': {'class': 'auth-form', 'id': 'register-form'}}) }}
				<div class="form-row">
					<div class="form-group half-width">
						<label for="{{ form.username.vars.id }}" class="form-label">Nome de Usuário
							<span class="form-required">*</span>
						</label>
						<div class="input-icon-wrapper">
							<i class="fa-solid fa-user input-icon"></i>
							{{ form_widget(form.username, {'attr': {'class': 'form-input', 'placeholder': 'Entre 3 e 30 caracteres...'}}) }}
						</div>
					</div>

					<div class="form-group half-width">
						<label for="{{ form.apelido.vars.id }}" class="form-label">Apelido
							<span class="form-hint">(opcional)</span>
						</label>
						<div class="input-icon-wrapper">
							<i class="fa-solid fa-user input-icon"></i>
							{{ form_widget(form.apelido, {'attr': {'class': 'form-input', 'placeholder': 'Como quer ser chamado...'}}) }}
						</div>
					</div>
				</div>

				<div class="form-row">
					<div class="form-group half-width">
						<label for="{{ form.password.first.vars.id }}" class="form-label">Senha
							<span class="form-required">*</span>
						</label>
						<div class="input-icon-wrapper">
							<i class="fa-solid fa-lock input-icon"></i>
							{{ form_widget(form.password.first, {'attr': {'class': 'form-input', 'placeholder': 'Mínimo 6 caracteres...'}}) }}
						</div>
					</div>

					<div class="form-group half-width">
						<label for="{{ form.password.second.vars.id }}" class="form-label">Confirmar Senha
							<span class="form-required">*</span>
						</label>
						<div class="input-icon-wrapper">
							<i class="fa-solid fa-lock input-icon"></i>
							{{ form_widget(form.password.second, {'attr': {'class': 'form-input', 'placeholder': 'Digite a senha novamente...'}}) }}
						</div>
					</div>
				</div>

				<div class="form-group">
					<label for="{{ form.regional.vars.id }}" class="form-label">Sua Região
						<span class="form-required">*</span>
					</label>
					<div class="input-icon-wrapper">
						{{ form_widget(form.regional, {'attr': {'class': 'form-input form-select'}}) }}
					</div>
				</div>

				<button type="submit" class="btn btn-primary btn-block">
					<i class="fa-solid fa-user-plus"></i>
					Registrar-se
				</button>
			{{ form_end(form) }}


			<div class="auth-footer">
				<p>Já possui uma conta?
					<a href="{{ path('app_login') }}" class="auth-link">Faça login aqui</a>
				</p>
			</div>
		</div>
	</div>
{% endblock %}
