					<i class="fa-solid fa-medal"></i>
					Escolha uma Medalha
				</h3>

				<button class="close-modal-btn" onclick="closeMedalPickerModal()">
					<i class="fa-solid fa-xmark"></i>
				</button>
			</div>

			<p class="medal-picker-subtitle">Selecione uma medalha conquistada para exibir no seu Trainer Card.</p>
			<div class="medal-picker-actions-top">
				<button class="btn btn-secondary btn-sm" onclick="removeMedalFromSlot()" id="remove-medal-btn">
					<i class="fa-solid fa-trash-can"></i>
					Remover Medalha
				</button>
			</div>

			<div class="medal-picker-grid" id="medal-picker-grid">
				{% for m in activityMedals|merge(catchMedals)|merge(regionalMedals)|merge(typeMedals) %}
					{% if m.tier != 'locked' and m.enabled %}

						<div class="medal-picker-option" data-medal-name="{{ m.name }}" onclick="selectShowcaseMedal('{{ m.name }}')">
							<div class="picker-medal-badge">

								{% if m.badgeImg %}
									<img src="{{ m.badgeImg }}" alt="{{ m.title }}" class="picker-badge-img">
								{% else %}
									<div class="picker-badge-icon">
										<i class="fa-solid {{ m.icon }}"></i>
									</div>
								{% endif %}

							</div>
							<div class="picker-medal-info">
								<span class="picker-medal-title">{{ m.title }}</span>
								<span class="picker-medal-tier tier-{{ m.tier }}">{{ m.tier|capitalize }}</span>
							</div>
						</div>
						
					{% endif %}
				{% endfor %}

			</div>
		</div>
	</div>

	<!-- Container Oculto com as URLs para o Javascript usar via AJAX -->
	<div id="trainer-card-data" style="display: none;" data-url-tm-toggle="{{ path('app_trainer_card_tm_toggle') }}" data-url-pokemon-toggle-catch="{{ path('app_trainer_card_pokemon_toggle_catch') }}" data-url-follow-toggle="{{ path('app_trainer_card_follow_toggle') }}" data-url-title-update="{{ path('app_trainer_card_title_update') }}" data-url-avatar-update="{{ path('app_trainer_card_avatar_update') }}" data-url-showcase-update="{{ path('app_trainer_card_showcase_update') }}" data-url-template-update="{{ path('app_trainer_card_template_update') }}"></div>

	{% include 'partials/tooltip.html.twig' %}
	<script src="{{ asset('js/trainer-card.js') }}"></script>
{% endblock %}
