{% extends 'base.html.twig' %}

{% block title %}{{ 'Ranking de Treinadores'|trans }} | PokeFlaton{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/trainer-card.css') }}">
	<link rel="stylesheet" href="{{ asset('css/ranking.css') }}">
{% endblock %}

{% block body %}
	<div class="ranking-page-container">
		<div class="ranking-header">
			{% if sort == 'likes' %}
				<h1 class="ranking-title">{{ 'Ranking de Curtidas'|trans }}</h1>
				<p class="ranking-subtitle">{{ 'Os treinadores mais aclamados e queridos pela comunidade do PokeFlaton.'|trans }}</p>
			{% else %}
				<h1 class="ranking-title">{{ 'Ranking de Medalhas'|trans }}</h1>
				<p class="ranking-subtitle">{{ 'Os treinadores com o maior número de insígnias e conquistas acumuladas.'|trans }}</p>
			{% endif %}
		</div>

		<div class="ranking-filters-bar">
			<form action="{{ path('app_trainer_ranking') }}" method="GET" class="ranking-search-form">
				<input type="hidden" name="sort" value="{{ sort }}">
				<div class="ranking-search-box">
					<input type="text" name="q" value="{{ search }}" placeholder="{{ 'Pesquisar treinador...'|trans }}" class="search-input" autocomplete="off">
					<i class="fa-solid fa-magnifying-glass search-icon"></i>
				</div>
			</form>

			<div class="ranking-sort-group">
				<a href="{{ path('app_trainer_ranking', { q: search, sort: 'medals' }) }}" class="sort-tab-btn {% if sort == 'medals' %}active{% endif %}">
					<i class="fa-solid fa-medal"></i>
					{{ 'Medalhas'|trans }}
				</a>
				<a href="{{ path('app_trainer_ranking', { q: search, sort: 'likes' }) }}" class="sort-tab-btn {% if sort == 'likes' %}active{% endif %}">
					<i class="fa-solid fa-heart"></i>
					{{ 'Curtidas'|trans }}
				</a>
			</div>
		</div>

		<div id="ranking-content-wrapper">
			{% include 'trainer_card/_ranking_content.html.twig' %}
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			const searchForm = document.querySelector('.ranking-search-form');
			const searchInput = document.querySelector('.search-input');
			const sortTabs = document.querySelectorAll('.sort-tab-btn');

			// Intercepta o submit do form de busca
			if (searchForm) {
				searchForm.addEventListener('submit', function(e) {
					e.preventDefault();
					performAjaxRequest();
				});
			}

			// Intercepta os clicks nas abas de ordenação
			sortTabs.forEach(function(btn) {
				btn.addEventListener('click', function(e) {
					e.preventDefault();
					
					// Atualiza a estilização da aba ativa
					sortTabs.forEach(t => t.classList.remove('active'));
					btn.classList.add('active');

					const url = new URL(btn.href);
					const sort = url.searchParams.get('sort') || 'medals';
					
					const hiddenSortInput = document.querySelector('input[name="sort"]');
					if (hiddenSortInput) {
						hiddenSortInput.value = sort;
					}

					performAjaxRequest(url);
				});
			});

			// Intercepta o link de limpar busca via delegação
			document.addEventListener('click', function(e) {
				const clearBtn = e.target.closest('.empty-ranking .btn');
				if (clearBtn) {
					e.preventDefault();
					if (searchInput) {
						searchInput.value = '';
					}
					performAjaxRequest(new URL(clearBtn.href));
				}
			});

			// Realiza a requisição AJAX
			function performAjaxRequest(customUrl) {
				if (window.Loader) {
					window.Loader.show();
				}

				let targetUrl;
				if (customUrl) {
					targetUrl = new URL(customUrl);
				} else {
					targetUrl = new URL(searchForm.action);
					const formData = new FormData(searchForm);
					for (const [key, value] of formData.entries()) {
						targetUrl.searchParams.set(key, value);
					}
				}

				targetUrl.searchParams.set('ajax', '1');

				fetch(targetUrl)
					.then(response => {
						if (!response.ok) {
							throw new Error('Erro na resposta do servidor');
						}
						return response.text();
					})
					.then(html => {
						const wrapper = document.getElementById('ranking-content-wrapper');
						if (wrapper) {
							wrapper.innerHTML = html;
						}

						// Atualiza o histórico do endereço da barra do navegador
						const historyUrl = new URL(targetUrl);
						historyUrl.searchParams.delete('ajax');
						history.pushState({}, '', historyUrl);

						// Atualiza o subtítulo e o título da página dependendo do tipo de ordenação selecionado
						const currentSort = targetUrl.searchParams.get('sort') || 'medals';
						const titleEl = document.querySelector('.ranking-title');
						const subtitleEl = document.querySelector('.ranking-subtitle');

						if (titleEl && subtitleEl) {
							if (currentSort === 'likes') {
								titleEl.textContent = '{{ "Ranking de Curtidas"|trans }}';
								subtitleEl.textContent = '{{ "Os treinadores mais aclamados e queridos pela comunidade do PokeFlaton."|trans }}';
							} else {
								titleEl.textContent = '{{ "Ranking de Medalhas"|trans }}';
								subtitleEl.textContent = '{{ "Os treinadores com o maior número de insígnias e conquistas acumuladas."|trans }}';
							}
						}

						// Atualiza os botões activos com base no novo estado
						const activeSort = targetUrl.searchParams.get('sort') || 'medals';
						sortTabs.forEach(btn => {
							const url = new URL(btn.href);
							const btnSort = url.searchParams.get('sort') || 'medals';
							if (btnSort === activeSort) {
								btn.classList.add('active');
							} else {
								btn.classList.remove('active');
							}
						});
					})
					.catch(error => {
						console.error('Erro ao carregar o ranking:', error);
					})
					.finally(() => {
						if (window.Loader) {
							window.Loader.hide();
						}
					});
			}
		});
	</script>
{% endblock %}