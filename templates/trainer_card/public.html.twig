{% extends 'base.html.twig' %}

{% block title %}Perfil de
	{{ targetUser.username }}
	| PokeFlaton
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/trainer-card.css') }}">
	<link rel="stylesheet" href="{{ asset('css/poke-types.css') }}">
	<style>
		.medal-card {
			position: relative;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="trainer-card-page-wrapper">

		<!-- Abas -->
		<div class="profile-tabs">
			<button class="tab-btn active" onclick="switchTab(event, 'trainer-card-tab')">
				<i class="fa-solid fa-address-card"></i>
				Trainer Card
			</button>
			<button class="tab-btn" onclick="switchTab(event, 'pokedex-tab')">
				<i class="fa-solid fa-square-poll-horizontal"></i>
				Pokedéx (<span id="pokedex-count-badge">{{ caughtCount }}</span>)
			</button>
			<button class="tab-btn" onclick="switchTab(event, 'medals-tab')">
				<i class="fa-solid fa-medal"></i>
				Medalhas
			</button>
		</div>

		<div id="trainer-card-tab" class="tab-content active">

			<!-- Trainer Card -->
			<div class="trainer-profile-banner" style="{% if selectedTemplateUrl %}background-image: linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)), url('{{ selectedTemplateUrl }}'); background-size: cover; background-position: center;{% endif %}">
				<div class="banner-glow"></div>
				<div class="banner-accent-line"></div>

				<div class="banner-content">
					<!-- Avatar + Info + Medal -->

					<div class="banner-row-top">
						<div class="banner-avatar-section">
							<div class="banner-avatar-frame" style="cursor: default;">
								<img src="https://raw.githubusercontent.com/smogon/sprites/master/src/_uncategorized/canonical/trainers/gen5/black2-white2/{{ targetUser.avatar }}" alt="Avatar" id="trainer-avatar-img" class="trainer-avatar-sprite">
							</div>
						</div>

						<div class="banner-info-section">
							<div class="banner-user-identity">
								<div class="banner-avatar-badge">
									<span class="banner-id-tag">#{{ "%05d"|format(targetUser.id) }}</span>
								</div>

								<h2 class="banner-username">{{ targetUser.username }}</h2>
								<span class="banner-join-date">
									<i class="fa-solid fa-calendar-days"></i>
									Membro desde
									{{ targetUser.createdAt|date('d/m/Y') }}
								</span>
							</div>

							<!-- Titulos -->
							{% set titleLabel %}

								{% if selectedRibbon %}
									<img src="{{ selectedRibbon }}" alt="Ribbon" class="banner-ribbon-sprite" style="width: 24px; height: 24px; object-fit: contain; image-rendering: pixelated; margin-right: 4px;">
								{% else %}
									<i class="fa-solid fa-crown"></i>
								{% endif %}
								
								<span class="achievement-label">{{ selectedTitle|default('Treinador Novato') }}</span>
							{% endset %}

							{% set titleContent %}
								<div class="tooltip-row tooltip-desc-row">
									<span class="tooltip-label">Como conseguir:</span>
									<span class="tooltip-value">{{ selectedTitleRequirement }}</span>
								</div>
							{% endset %}

							{% include 'partials/tooltip_trigger.html.twig' with {
								'tag': 'div',
								'class': 'banner-achievement-title',
								'style': 'cursor: pointer;',
								'title': selectedTitle|default('Treinador Novato'),
								'label': titleLabel,
								'content': titleContent
							} %}
						</div>

						<!-- Medalhas destaque -->
						<div class="banner-medal-showcase">
							<span class="showcase-title">
								<i class="fa-solid fa-medal"></i>
								Medalhas em Destaque
							</span>

							<div class="showcase-slots">
								{% for i in 0..3 %}
									{% set showcaseMedal = targetUser.showcaseMedals[i] | default(null) %}

									<div class="showcase-slot {% if showcaseMedal %}filled{% else %}empty{% endif %}" data-slot="{{ i }}" style="cursor: default;" title="{% if showcaseMedal %}{{ showcaseMedal }}{% else %}Sem medalha destacada{% endif %}">
										{% if showcaseMedal %}
											{% set foundMedal = null %}
											
											{% for m in activityMedals|merge(catchMedals)|merge(regionalMedals)|merge(typeMedals) %}
												{% if m.name == showcaseMedal and m.tier != 'locked' and m.enabled %}
													{% set foundMedal = m %}
												{% endif %}
											{% endfor %}

											{% if foundMedal and foundMedal.badgeImg %}
												<img src="{{ foundMedal.badgeImg }}" alt="{{ foundMedal.title }}" class="showcase-medal-img">
												<span class="showcase-medal-name">{{ foundMedal.title }}</span>
											{% elseif foundMedal %}
												<div class="showcase-medal-icon">
													<i class="fa-solid {{ foundMedal.icon }}"></i>
												</div>
												<span class="showcase-medal-name">{{ foundMedal.title }}</span>
											{% else %}
												<div class="showcase-slot-empty"></div>
											{% endif %}

										{% else %}
											<div class="showcase-slot-empty"></div>
										{% endif %}

									</div>
								{% endfor %}

							</div>
						</div>
					</div>

					<div class="banner-row-bottom">
						<div class="banner-stats-section">

							<div class="banner-stat-item">
								<span class="banner-stat-value" id="card-votes-count">{{ totalVotes }}</span>
								<span class="banner-stat-label">
									<i class="fa-solid fa-heart"></i>
									Curtidas
								</span>
							</div>

							<div class="banner-stat-divider"></div>
							<div class="banner-stat-item">
								<span class="banner-stat-value">{{ createdCount }}</span>
								<span class="banner-stat-label">
									<i class="fa-solid fa-flask"></i>
									Movesets
								</span>
							</div>

							<div class="banner-stat-divider"></div>
							<div class="banner-stat-item">
								<span class="banner-stat-value">{{ followingCount }}</span>
								<span class="banner-stat-label">
									<i class="fa-solid fa-user-plus"></i>
									Seguindo
								</span>
							</div>

							<div class="banner-stat-divider"></div>
							<div class="banner-stat-item">
								<span class="banner-stat-value" id="followers-count-display">{{ followersCount }}</span>
								<span class="banner-stat-label">
									<i class="fa-solid fa-users"></i>
									Seguidores
								</span>
							</div>
						</div>

						<!-- Seção de ações -->
						<div class="banner-actions-section">
							{% if app.user %}

								{% if app.user.username != targetUser.username %}
									{% set isFollowing = targetUser.username in app.user.following %}

									<button id="follow-btn" class="btn {% if isFollowing %}btn-secondary{% else %}btn-primary{% endif %} btn-block" onclick="toggleFollowTrainer('{{ targetUser.username }}')">
										<i class="fa-solid {% if isFollowing %}fa-user-minus{% else %}fa-user-plus{% endif %}"></i>
										<span class="btn-text">
											{% if isFollowing %}Deixar de Seguir{% else %}Seguir Treinador
											{% endif %}
										</span>
									</button>
								{% else %}
									<div class="profile-self-notice" style="background: rgba(255, 255, 255, 0.04); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 10px 18px; font-size: 0.85rem; color: var(--text-secondary); display: flex; align-items: center; gap: 8px;">
										<i class="fa-solid fa-circle-info" style="color: var(--color-secondary);"></i>
										<span>Seu perfil público</span>
									</div>
								{% endif %}

							{% else %}
								<div class="follow-prompt" style="font-size: 0.85rem; color: var(--text-muted);">
									<span>Faça
										<a href="{{ path('app_login') }}" style="color: var(--color-secondary); font-weight: 600;">login</a>
										para seguir.
									</span>
								</div>
							{% endif %}

						</div>
					</div>
				</div>

				<!-- Footer -->
				<div class="banner-footer-strip">
					<div class="footer-ball-icon"></div>
					<span class="region-text">
						REGIÃO DE
						{{ targetUser.regional|upper }}
					</span>
				</div>
			</div>

			<!-- Mochila de TMs -->
			<div class="technical-machine-section trainer-section-collapsible">
				<div class="trainer-section-header" onclick="toggleCategorySection('tms-content-section', 'tms-chevron')">
					<h2 class="trainer-card-title">Mochila de TMs</h2>
					<i class="fa-solid fa-chevron-down trainer-section-chevron" id="tms-chevron"></i>
				</div>

				<div id="tms-content-section" class="trainer-section-content">
					<div class="tms-container card">
						<div class="tms-header">
							<p>Cassetes de golpes técnicos (TMs) desbloqueados por este treinador.</p>
						</div>

						{% set unlockedTmsList = [] %}

						{% for tm in tms %}
							{% if tm.move in targetUser.unlockedTms %}
								{% set unlockedTmsList = unlockedTmsList|merge([tm]) %}
							{% endif %}
						{% endfor %}

						{% if unlockedTmsList is empty %}
							<div style="text-align: center; padding: 30px; color: var(--text-secondary);">
								<i class="fa-solid fa-circle-info" style="font-size: 2rem; color: var(--text-muted); margin-bottom: 12px; display: block;"></i>
								Este treinador ainda não desbloqueou nenhuma TM.
							</div>
						{% else %}
							<div class="tms-grid">
								{% for tm in unlockedTmsList %}
									{% set tmNumber = tm.item|upper %}
									{% set moveDisplayName = tm.move|replace({'-': ' '})|title %}

									<div class="tm-disc-card active" style="cursor: default;">
										<div class="disc-graphic">
											<div class="disc-inner"></div>
										</div>

										<div class="tm-info">
											<span class="tm-number">{{ tmNumber }}</span>
											<span class="tm-move-name" title="{{ moveDisplayName }}">{{ moveDisplayName }}</span>
										</div>
									</div>
								{% endfor %}
							</div>

						{% endif %}
					</div>

				</div>
			</div>

		</div>

		<!-- Pokedex Catch -->
		<div id="pokedex-tab" class="tab-content">
			<div class="pokedex-list-container card">
				<div class="tms-header">
					<h2>Pokedéx de
						{{ targetUser.username }}</h2>
					<p>Confira todos os Pokémons capturados por este treinador na sua jornada!</p>
				</div>

				{% if caughtDetails is empty %}
					<div class="empty-pokedex-msg" style="text-align: center; padding: 40px; color: var(--text-secondary);">
						<i class="fa-solid fa-circle-exclamation" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 15px; display: block;"></i>
						<h3>Nenhum Pokémon capturado ainda!</h3>
					</div>
				{% else %}
					<div class="pokedex-caught-grid">
						{% for poke in caughtDetails %}

							<div class="pokedex-caught-card border-type-{{ poke.types|first }}" id="caught-card-{{ poke.name }}">
								<div class="caught-card-inner">
									<a href="{{ path('app_pokemon_detail', { name: poke.name }) }}" class="poke-sprite-link">
										<img src="{{ poke.sprite }}" alt="{{ poke.name|capitalize }}" class="poke-sprite-img">
									</a>
									<span class="poke-id">Nº
										{{ "%04d"|format(poke.id) }}</span>
									<a href="{{ path('app_pokemon_detail', { name: poke.name }) }}" class="poke-name-link">
										<span class="poke-name-text">{{ poke.name|capitalize }}</span>
									</a>
									<div class="poke-badges-container">
										{% for type in poke.types %}
											<span class="type-badge-sm type-badge-pd type-badge-{{ type }}">{{ type|capitalize }}</span>
										{% endfor %}
									</div>
								</div>
							</div>
						{% endfor %}

					</div>
				{% endif %}

			</div>
		</div>

		<!-- Medalhas -->
		<div id="medals-tab" class="tab-content">
			<div class="medals-layout-container">
				<div class="medals-title-header">
					<h2>Conquistas do Treinador -
						{{ targetUser.username }}</h2>
					<p>Progresso e conquistas deste treinador.</p>
				</div>

				<!-- Categoria 1: Conquistas de Atividade e Comunidade -->
				<div class="medals-section-category trainer-section-collapsible">
					<div class="trainer-section-header" onclick="toggleCategorySection('medal-activity-section', 'medal-activity-chevron')">
						<h3 class="medals-category-title">
							<i class="fa-solid fa-trophy"></i>
							Conquistas de Atividade e Comunidade
						</h3>
						<i class="fa-solid fa-chevron-down trainer-section-chevron" id="medal-activity-chevron"></i>
					</div>

					<div id="medal-activity-section" class="trainer-section-content">

						<div class="medals-grid">
							{% for medal in activityMedals %}

								<div class="medal-card card medal-tier-{{ medal.tier }} {% if not medal.enabled %}medal-admin-locked{% endif %}" id="medal-card-{{ medal.name }}" data-tooltip-title="{{ medal.title }}" onmouseenter="showTemplateTooltip(event)" onmouseleave="hideGenericTooltip()">
									<div class="medal-badge-wrapper">

										{% if not medal.enabled %}
											<div class="medal-badge medal-badge-admin-locked">
												<i class="fa-solid fa-lock"></i>
											</div>
										{% else %}
											{% if medal.badgeImg %}
												<img src="{{ medal.badgeImg }}" alt="{{ medal.title }}" class="medal-badge-img {% if medal.tier == 'locked' %}medal-badge-locked{% endif %}" loading="lazy">
											{% else %}
												<div class="medal-badge">
													<i class="fa-solid {{ medal.icon }}"></i>
												</div>
											{% endif %}
										{% endif %}
									</div>

									<div class="medal-info">
										<h4 class="medal-title">{{ medal.title }}</h4>
										<p class="medal-desc">
											{{ medal.description }}
										</p>

										{% if medal.enabled %}
											<div class="medal-progress-section">
												<div class="medal-progress-bar-container">
													<div class="medal-progress-fill" style="width: {{ medal.percent }}%;"></div>
												</div>
												<div class="medal-progress-text">
													<span class="progress-current">{{ medal.current }}</span>

													{% if medal.nextTarget %}
														<span class="progress-separator">/</span>
														<span class="progress-target">{{ medal.nextTarget }}</span>
													{% else %}
														<span class="progress-max">(Máximo)</span>
													{% endif %}
												</div>
											</div>

											<div class="medal-milestones">
												<div class="milestone {% if medal.current >= medal.milestones.bronze %}reached{% endif %}">
													<span class="tier-dot bronze"></span>
													B:
													{{ medal.milestones.bronze }}
												</div>
												<div class="milestone {% if medal.current >= medal.milestones.silver %}reached{% endif %}">
													<span class="tier-dot silver"></span>
													P:
													{{ medal.milestones.silver }}
												</div>
												<div class="milestone {% if medal.current >= medal.milestones.gold %}reached{% endif %}">
													<span class="tier-dot gold"></span>
													O:
													{{ medal.milestones.gold }}
												</div>
											</div>
										{% else %}
											<div class="medal-status-admin-locked">
												<span class="badge-status-locked">
													<i class="fa-solid fa-lock"></i>
													EM BREVE
												</span>
											</div>
										{% endif %}
									</div>

									<!-- Tooltip -->
									{% include 'partials/medal_tooltip.html.twig' %}

								</div>
							{% endfor %}

						</div>
					</div>
				</div>

				<!-- Categoria 2: Enciclopédia -->
				<div class="medals-section-category mt-5 trainer-section-collapsible">
					<div class="trainer-section-header" onclick="toggleCategorySection('medal-encyclopedia-section', 'medal-encyclopedia-chevron')">
						<h3 class="medals-category-title">
							<i class="fa-solid fa-book-open"></i>
							Enciclopédia Pokémon
						</h3>
						<i class="fa-solid fa-chevron-down trainer-section-chevron" id="medal-encyclopedia-chevron"></i>
					</div>

					<div id="medal-encyclopedia-section" class="trainer-section-content">
						<div class="medals-section-category">

							<div class="medals-title-header">
								<h4>Explorador</h4>
								<p class="text-muted">Conquistas gerais por metas de exploração.</p>
							</div>

							<div class="medals-grid">
								{% for medal in catchMedals %}

									<div class="medal-card card medal-tier-{{ medal.tier }} {% if not medal.enabled %}medal-admin-locked{% endif %}" id="medal-card-{{ medal.name }}" data-tooltip-title="{{ medal.title }}" onmouseenter="showTemplateTooltip(event)" onmouseleave="hideGenericTooltip()">
										<div class="medal-badge-wrapper">

											{% if not medal.enabled %}
												<div class="medal-badge medal-badge-admin-locked">
													<i class="fa-solid fa-lock"></i>
												</div>
											{% else %}
												{% if medal.badgeImg %}
													<img src="{{ medal.badgeImg }}" alt="{{ medal.title }}" class="medal-badge-img {% if medal.tier == 'locked' %}medal-badge-locked{% endif %}" loading="lazy">
												{% else %}
													<div class="medal-badge">
														<i class="fa-solid {{ medal.icon }}"></i>
													</div>
												{% endif %}
											{% endif %}
										</div>

										<div class="medal-info">
											<h4 class="medal-title">{{ medal.title }}</h4>
											<p class="medal-desc">
												{{ medal.description }}
											</p>

											{% if medal.enabled %}
												<div class="medal-progress-section">
													<div class="medal-progress-bar-container">
														<div class="medal-progress-fill" style="width: {{ medal.percent }}%;"></div>
													</div>

													<div class="medal-progress-text">
														<span class="progress-current">{{ medal.current }}</span>
														{% if medal.nextTarget %}
															<span class="progress-separator">/</span>
															<span class="progress-target">{{ medal.nextTarget }}</span>
														{% else %}
															<span class="progress-max">(Máximo)</span>
														{% endif %}
													</div>
												</div>

												<div class="medal-milestones">
													<div class="milestone {% if medal.current >= medal.milestones.bronze %}reached{% endif %}">
														<span class="tier-dot bronze"></span>
														B:
														{{ medal.milestones.bronze }}
													</div>
													<div class="milestone {% if medal.current >= medal.milestones.silver %}reached{% endif %}">
														<span class="tier-dot silver"></span>
														P:
														{{ medal.milestones.silver }}
													</div>
													<div class="milestone {% if medal.current >= medal.milestones.gold %}reached{% endif %}">
														<span class="tier-dot gold"></span>
														O:
														{{ medal.milestones.gold }}
													</div>
												</div>
											{% else %}
												<div class="medal-status-admin-locked">
													<span class="badge-status-locked">
														<i class="fa-solid fa-lock"></i>
														EM BREVE
													</span>
												</div>
											{% endif %}
										</div>

										{% include 'partials/medal_tooltip.html.twig' %}
									</div>
								{% endfor %}

							</div>
						</div>

						<div class="medals-section-category" style="margin-top: 30px;">
							<div class="medals-title-header">
								<h4>Capturas de Tipos</h4>
								<p class="text-muted">Suba de nível capturando diferentes espécies de cada tipo.</p>
							</div>

							<div class="medals-grid types-medals-grid">
								{% for medal in typeMedals %}
									{% set typeKey = medal.name|replace({'type_': ''}) %}

									<div class="medal-card card medal-tier-{{ medal.tier }} medal-type-card border-type-{{ typeKey }} {% if not medal.enabled %}medal-admin-locked{% endif %}" id="medal-card-{{ medal.name }}" data-tooltip-title="{{ medal.title }}" onmouseenter="showTemplateTooltip(event)" onmouseleave="hideGenericTooltip()">
										<div class="medal-badge-wrapper">

											{% if not medal.enabled %}
												<div class="medal-badge medal-badge-admin-locked">
													<i class="fa-solid fa-lock"></i>
												</div>
											{% else %}
												{% if medal.badgeImg %}
													<img src="{{ medal.badgeImg }}" alt="{{ medal.title }}" class="medal-badge-img {% if medal.tier == 'locked' %}medal-badge-locked{% endif %}" loading="lazy">
												{% else %}
													<div class="medal-badge type-color-badge-{{ typeKey }}">
														<i class="fa-solid {{ medal.icon }}"></i>
													</div>
												{% endif %}
											{% endif %}
										</div>

										<div class="medal-info">
											<h4 class="medal-title">{{ medal.title }}</h4>
											<span class="type-badge-sm type-badge-pd type-badge-{{ typeKey }}" style="display: inline-block; margin-bottom: 8px;">{{ typeKey|capitalize }}</span>
											<p class="medal-desc">
												{{ medal.description }}
											</p>

											{% if medal.enabled %}
												<div class="medal-progress-section">
													<div class="medal-progress-bar-container">
														<div class="medal-progress-fill" style="width: {{ medal.percent }}%;"></div>
													</div>

													<div class="medal-progress-text">
														<span class="progress-current">{{ medal.current }}</span>
														{% if medal.nextTarget %}
															<span class="progress-separator">/</span>
															<span class="progress-target">{{ medal.nextTarget }}</span>
														{% else %}
															<span class="progress-max">(Máximo)</span>
														{% endif %}
													</div>
												</div>

												<div class="medal-milestones">
													<div class="milestone {% if medal.current >= medal.milestones.bronze %}reached{% endif %}">
														<span class="tier-dot bronze"></span>
														B:
														{{ medal.milestones.bronze }}
													</div>
													<div class="milestone {% if medal.current >= medal.milestones.silver %}reached{% endif %}">
														<span class="tier-dot silver"></span>
														P:
														{{ medal.milestones.silver }}
													</div>
													<div class="milestone {% if medal.current >= medal.milestones.gold %}reached{% endif %}">
														<span class="tier-dot gold"></span>
														O:
														{{ medal.milestones.gold }}
													</div>
												</div>
											{% else %}
												<div class="medal-status-admin-locked">
													<span class="badge-status-locked">
														<i class="fa-solid fa-lock"></i>
														EM BREVE
													</span>
												</div>
											{% endif %}
										</div>

										<!-- Tooltip -->
										{% include 'partials/medal_tooltip.html.twig' %}
									</div>

								{% endfor %}
							</div>

						</div>
					</div>
				</div>

				<!-- Categoria 3: Medalhas de Pokédex Regional -->
				<div class="medals-section-category mt-5 trainer-section-collapsible">
					<div class="trainer-section-header" onclick="toggleCategorySection('medal-regional-section', 'medal-regional-chevron')">
						<h3 class="medals-category-title">
							<i class="fa-solid fa-map-location-dot"></i>
							Medalhas de Pokédex Regional
						</h3>
						<i class="fa-solid fa-chevron-down trainer-section-chevron" id="medal-regional-chevron"></i>
					</div>

					<div id="medal-regional-section" class="trainer-section-content">
						<div class="medals-grid">
							{% for medal in regionalMedals %}

								<div class="medal-card card medal-tier-{{ medal.tier }} {% if not medal.enabled %}medal-admin-locked{% endif %}" id="medal-card-{{ medal.name }}" data-tooltip-title="{{ medal.title }}" onmouseenter="showTemplateTooltip(event)" onmouseleave="hideGenericTooltip()">
									<div class="medal-badge-wrapper">
										{% if not medal.enabled %}
											<div class="medal-badge medal-badge-admin-locked">
												<i class="fa-solid fa-lock"></i>
											</div>
										{% else %}
											{% if medal.badgeImg %}
												<img src="{{ medal.badgeImg }}" alt="{{ medal.title }}" class="medal-badge-img {% if medal.tier == 'locked' %}medal-badge-locked{% endif %}" loading="lazy">
											{% else %}
												<div class="medal-badge">
													<i class="fa-solid {{ medal.icon }}"></i>
												</div>
											{% endif %}
										{% endif %}
									</div>

									<div class="medal-info">
										<h4 class="medal-title">{{ medal.title }}</h4>
										<p class="medal-desc">
											{{ medal.description }}
										</p>

										{% if medal.enabled %}
											<div class="medal-progress-section">
												<div class="medal-progress-bar-container">
													<div class="medal-progress-fill" style="width: {{ medal.percent }}%;"></div>
												</div>
												<div class="medal-progress-text">
													<span class="progress-current">{{ medal.current }}</span>
													{% if medal.nextTarget %}
														<span class="progress-separator">/</span>
														<span class="progress-target">{{ medal.nextTarget }}</span>
													{% else %}
														<span class="progress-max">(Máximo)</span>
													{% endif %}
												</div>
											</div>

											<div class="medal-milestones">
												<div class="milestone {% if medal.current >= medal.milestones.bronze %}reached{% endif %}">
													<span class="tier-dot bronze"></span>
													B:
													{{ medal.milestones.bronze }}
												</div>
												<div class="milestone {% if medal.current >= medal.milestones.silver %}reached{% endif %}">
													<span class="tier-dot silver"></span>
													P:
													{{ medal.milestones.silver }}
												</div>
												<div class="milestone {% if medal.current >= medal.milestones.gold %}reached{% endif %}">
													<span class="tier-dot gold"></span>
													O:
													{{ medal.milestones.gold }}
												</div>
											</div>
										{% else %}
											<div class="medal-status-admin-locked">
												<span class="badge-status-locked">
													<i class="fa-solid fa-lock"></i>
													EM BREVE
												</span>
											</div>
										{% endif %}
									</div>

									<!-- Tooltip -->
									{% include 'partials/medal_tooltip.html.twig' %}
								</div>

							{% endfor %}
						</div>

					</div>
				</div>

				<!-- Categoria 5: Vivillon's Patterns -->
				<div class="medals-section-category mt-5 trainer-section-collapsible">
					<div class="trainer-section-header" onclick="toggleCategorySection('medal-vivillon-section', 'medal-vivillon-chevron')">
						<h3 class="medals-category-title">
							<i class="fa-solid fa-leaf"></i>
							Vivillon's Patterns
						</h3>
						<i class="fa-solid fa-chevron-down trainer-section-chevron" id="medal-vivillon-chevron"></i>
					</div>

					<div id="medal-vivillon-section" class="trainer-section-content">
						<p class="text-muted mb-4" style="margin-top: -5px; font-size: 0.9rem;">Cada padrão de Vivillon é exclusivo de uma região real do mundo. Colecione todos os 20!</p>
						<div class="vivillon-patterns-grid">

							{% for pattern in vivillonMedals %}
								<div class="vivillon-pattern-card {% if not pattern.enabled %}vivillon-admin-locked{% elseif pattern.unlocked %}vivillon-unlocked{% else %}vivillon-locked{% endif %}" id="viv-card-{{ pattern.key }}">
									<div class="vivillon-sprite-wrapper">
										<img src="{{ pattern.sprite }}" alt="Vivillon {{ pattern.label }}" class="vivillon-sprite" loading="lazy">

										{% if not pattern.enabled %}
											<div class="vivillon-overlay">
												<i class="fa-solid fa-lock"></i>
											</div>
										{% elseif not pattern.unlocked %}
											<div class="vivillon-overlay vivillon-missing-overlay">
												<i class="fa-solid fa-question"></i>
											</div>
										{% endif %}
									</div>

									<div class="vivillon-pattern-info">
										<span class="vivillon-pattern-name">{{ pattern.label }}</span>

										{% if not pattern.enabled %}
											<span class="vivillon-status vivillon-status-admin">
												<i class="fa-solid fa-lock"></i>
												Em Breve</span>
										{% elseif pattern.unlocked %}
											<span class="vivillon-status vivillon-status-unlocked">
												<i class="fa-solid fa-check"></i>
												Coletado</span>
										{% else %}
											<span class="vivillon-status vivillon-status-locked">Por coletar</span>
										{% endif %}
									</div>
									
								</div>
							{% endfor %}

						</div>
					</div>
				</div>

			</div>
		</div>

	</div>

	<!-- Container Oculto com a URL via Twig para o JS -->
	<div id="public-profile-data" style="display: none;" data-url-follow-toggle="{{ path('app_trainer_card_follow_toggle') }}"></div>

	{% include 'partials/tooltip.html.twig' %}
	<script src="{{ asset('js/public-profile.js') }}"></script>
{% endblock %}
