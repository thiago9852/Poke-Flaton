# Token do seu bot do Discord (gerado no Discord Developer Portal)
DISCORD_TOKEN=

# ID da aplicação do bot (encontrado na aba General Information no Developer Portal)
CLIENT_ID=

# ID do seu servidor do Discord (para registrar comandos slash instantaneamente para testes)
GUILD_ID=seu_guild_id_aqui

# URL Base onde o seu projeto Symfony está rodando local ou em produção
# Se rodando localmente com o Symfony Server, geralmente é http://localhost:8000
API_BASE_URL=http://localhost:8000

# IDs dos canais do Discord onde apenas comandos slash (/) são permitidos (separados por vírgula)
# Deixe em branco se não quiser bloquear nenhum canal
COMMAND_CHANNELS=

#IDs dos canais do Discord onde apenas ANEXOS são permitidos
# Deixe em branco se não quiser bloquear nenhum canal
IMAGE_ONLY_CHANNELS=

# ID do canal de logs do servidor onde as transcrições de tickets serão salvas (deixe em branco se não quiser salvar no servidor)
TICKET_LOG_CHANNEL=

# Restrições de canais específicos para comandos (deixe em branco para permitir em qualquer canal)
CHANNEL_POKEMON=
CHANNEL_MOVESET=
CHANNEL_NATURE=
COUNTING_CHANNEL=
ALL_COMMANDS=
CHANNEL_ECONOMIA=
CHANNEL_BATTLE=


